#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
TEMPLATE_DIR="$ROOT/templates/graymatter-light-bootstrap"
OUT_DIR="${1:-graymatter-light-bundle}"
SERVER_URL="${GRAYMATTER_LIGHT_PUBLIC_URL:-http://localhost:8080}"

if [[ ! -d "$TEMPLATE_DIR" ]]; then
  echo "GrayMatter Light template directory missing: $TEMPLATE_DIR" >&2
  exit 1
fi

mkdir -p "$OUT_DIR"
cp -R "$TEMPLATE_DIR"/. "$OUT_DIR"/
mkdir -p "$OUT_DIR/dashboard" "$OUT_DIR/data" "$OUT_DIR/local-server/data"

sed "s#{{server_url}}#$SERVER_URL#g" "$OUT_DIR/api.hbs.yaml" >"$OUT_DIR/api.yaml"

chmod +x "$OUT_DIR/local-server/bin/graymatter-local-server" 2>/dev/null || true

printf 'Created GrayMatter Light bundle at %s\n' "$(cd "$OUT_DIR" && pwd)"
printf 'Next: docker compose up -d or local-server/bin/graymatter-local-server\n'
