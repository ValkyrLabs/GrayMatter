#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
SPEC="${1:-}"
if [[ -z "$SPEC" ]]; then
  SPEC="$("${SCRIPT_DIR}/gm-openapi-sync")"
elif [[ ! -f "$SPEC" ]]; then
  "${SCRIPT_DIR}/gm-openapi-sync" "$SPEC" >/dev/null
fi

jq -r '
  def interesting:
    [
      "GrayMatter","MemoryEntry","SwarmOps","Organization","Customer","Opportunity","Invoice",
      "Product","Application","Workbook","Workflow","Task","Note","MediaObject","FileRecord",
      "SalesActivity","SalesPipeline","Goal","StrategicPriority","KeyMetric","Agent","Space"
    ];
  def interesting_lower: interesting | map(ascii_downcase);
  def tags_by_name:
    (.tags // [])
    | map(select(.name))
    | map({key:.name, value:(.description // "")})
    | from_entries;

  "OpenAPI: \(.info.title // "unknown") v\(.info.version // "?")",
  "Tags: \((.tags // []) | length)",
  "Paths: \((.paths // {}) | length)",
  "",
  "Key domains:",
  (tags_by_name as $tags | interesting[] | select($tags[.] != null) | "- \(.)" + (if $tags[.] == "" then "" else ": \($tags[.])" end)),
  "",
  "Key endpoints:",
  ((.paths // {}) | to_entries | sort_by(.key)[] as $entry
    | select(any(interesting_lower[]; $entry.key | ascii_downcase | contains(.)))
    | "- \($entry.value | keys | map(ascii_upcase) | sort | join(",")) \($entry.key)")
' "$SPEC"
