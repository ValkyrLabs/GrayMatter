#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  gm-query <query> [limit] [type] [sourceChannel] [options]
  gm-query <query> --limit <n> [--type <type>] [--source-channel <source>] [options]

Query GrayMatter durable memory through POST /MemoryEntry/query.

Arguments:
  query
      Search text. Quote multi-word queries.

  limit
      Optional positional maximum result count. Defaults to 10.

  type
      Optional positional MemoryEntry type filter. Common values:
      decision, todo, context, artifact, preference.

  sourceChannel
      Optional positional retrieval scope/source filter. Prefer stable scope
      keys such as codex:workspace:2026-05-12/my-project or
      codex:automation:mcp-and-skill-hunter.

Options:
  --limit <n>
      Maximum number of results to request. Must be a non-negative integer.
      Overrides the positional limit when both are provided.

  --type <type>
      MemoryEntry type filter. Overrides the positional type.

  --source-channel <source>
      Explicit sourceChannel/source filter. Overrides derived scope.

  --format <json|brief|english>
      Output format. Defaults to json for scripting compatibility.

  --brief
  --english
  --summary
      Print a bounded, human-readable summary instead of raw JSON.

  --text-max <n>
      Maximum text characters per entry for brief/english output. Defaults to 220.

  --runtime <name>
      Runtime prefix used when deriving sourceChannel values. Defaults to codex.

  --scope-path <path>
  --artifact-path <path>
  --path <path>
      Derive sourceChannel from a known local path when no explicit
      sourceChannel is provided. Recognized patterns include:
        $HOME/.codex/automations/<automation-id>/...
        .../Documents/Codex/<date>/<workspace-slug>/...

  --workspace-key <key>
      Derive sourceChannel as <runtime>:workspace:<key>, unless key already
      contains ':'.

  --chat-key <key>
      Derive sourceChannel as <runtime>:chat:<key>, unless key already
      contains ':'. Chat scope has the highest precedence.

  --session-key <key>
      Derive sourceChannel as <runtime>:session:<key>, unless key already
      contains ':'.

  --automation-id <id>
      Derive sourceChannel as <runtime>:automation:<id>, unless id already
      contains ':'.

  -h, --help
      Show this help text.

Scope precedence:
  1. explicit positional sourceChannel or --source-channel
  2. --chat-key
  3. --session-key
  4. --automation-id
  5. --workspace-key
  6. recognized --scope-path / --artifact-path / --path

Examples:
  gm-query "GrayMatter launch status"
  gm-query "publish blocked" 5 context
  gm-query "handoff" --limit 5 --type context --chat-key thread-42
  gm-query "publish blocked" 5 context \
    --scope-path "$HOME/.codex/automations/mcp-and-skill-hunter/memory.md"
  gm-query "local memory" --source-channel codex:workspace:2026-05-12/demo

Output:
  Prints the JSON response returned by GrayMatter by default. Use --brief or
  --english for bounded human-readable output. The request body sent to
  /MemoryEntry/query includes q, maxResults, and optional type/source fields.

Environment:
  VALKYR_API_BASE
      API base URL. Defaults inside graymatter_api.sh to hosted api-0 unless
      overridden, for example by GrayMatter Light env exports.

  VALKYR_AUTH_TOKEN, VALKYR_JWT_SESSION, VALKYR_AUTH
      Auth sources used by graymatter_api.sh for hosted GrayMatter.

Notes:
  - Run scripts/gm-login or scripts/gm-activate before querying hosted api-0.
  - For GrayMatter Light, run scripts/gm-light-up, then source
    .graymatter-light/.graymatter-light-env before gm-query.
  - Hosted memory query may consume account credits.
EOF
}

require_value() {
  local option="$1"
  local value="${2:-}"
  if [[ -z "$value" || "$value" == --* ]]; then
    echo "gm-query: $option requires a value" >&2
    echo "Run 'gm-query --help' for usage." >&2
    exit 1
  fi
}

QUERY="${1:-}"

if [[ "$QUERY" == "-h" || "$QUERY" == "--help" ]]; then
  usage
  exit 0
fi

if [[ -z "$QUERY" ]]; then
  usage >&2
  exit 1
fi

shift

LIMIT="10"
TYPE=""
SOURCE_CHANNEL=""
if [[ $# -gt 0 && "${1:-}" != --* ]]; then
  LIMIT="$1"
  shift
fi
if [[ $# -gt 0 && "${1:-}" != --* ]]; then
  TYPE="$1"
  shift
fi
if [[ $# -gt 0 && "${1:-}" != --* ]]; then
  SOURCE_CHANNEL="$1"
  shift
fi

RUNTIME="codex"
WORKSPACE_KEY=""
CHAT_KEY=""
SESSION_KEY=""
AUTOMATION_ID=""
SCOPE_PATH=""
OUTPUT_FORMAT="${GRAYMATTER_QUERY_FORMAT:-json}"
TEXT_MAX="${GRAYMATTER_QUERY_TEXT_MAX:-220}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --runtime)
      require_value "$1" "${2:-}"
      RUNTIME="${2:-}"
      shift 2
      ;;
    --workspace-key)
      require_value "$1" "${2:-}"
      WORKSPACE_KEY="${2:-}"
      shift 2
      ;;
    --chat-key)
      require_value "$1" "${2:-}"
      CHAT_KEY="${2:-}"
      shift 2
      ;;
    --session-key)
      require_value "$1" "${2:-}"
      SESSION_KEY="${2:-}"
      shift 2
      ;;
    --automation-id)
      require_value "$1" "${2:-}"
      AUTOMATION_ID="${2:-}"
      shift 2
      ;;
    --scope-path|--artifact-path|--path)
      require_value "$1" "${2:-}"
      SCOPE_PATH="${2:-}"
      shift 2
      ;;
    --source-channel)
      require_value "$1" "${2:-}"
      SOURCE_CHANNEL="${2:-}"
      shift 2
      ;;
    --type)
      require_value "$1" "${2:-}"
      TYPE="${2:-}"
      shift 2
      ;;
    --limit)
      require_value "$1" "${2:-}"
      LIMIT="${2:-}"
      shift 2
      ;;
    --format)
      require_value "$1" "${2:-}"
      OUTPUT_FORMAT="${2:-}"
      shift 2
      ;;
    --brief|--english|--summary)
      OUTPUT_FORMAT="english"
      shift
      ;;
    --text-max)
      require_value "$1" "${2:-}"
      TEXT_MAX="${2:-}"
      shift 2
      ;;
    *)
      echo "Unknown gm-query option: $1" >&2
      echo "Run 'gm-query --help' for usage." >&2
      exit 1
      ;;
  esac
done

if [[ ! "$LIMIT" =~ ^[0-9]+$ ]]; then
  echo "gm-query: limit must be a non-negative integer: $LIMIT" >&2
  exit 1
fi
if [[ ! "$TEXT_MAX" =~ ^[0-9]+$ || "$TEXT_MAX" -lt 40 ]]; then
  echo "gm-query: --text-max must be an integer >= 40: $TEXT_MAX" >&2
  exit 1
fi
case "$OUTPUT_FORMAT" in
  json|brief|english) ;;
  *)
    echo "gm-query: --format must be json, brief, or english: $OUTPUT_FORMAT" >&2
    exit 1
    ;;
esac

derive_source_channel() {
  local path="$1"
  if [[ -n "$CHAT_KEY" ]]; then
    scoped_key chat "$CHAT_KEY"
  elif [[ -n "$SESSION_KEY" ]]; then
    scoped_key session "$SESSION_KEY"
  elif [[ -n "$AUTOMATION_ID" ]]; then
    scoped_key automation "$AUTOMATION_ID"
  elif [[ -n "$WORKSPACE_KEY" ]]; then
    scoped_key workspace "$WORKSPACE_KEY"
  elif [[ "$path" =~ \.codex/automations/([^/]+) ]]; then
    printf '%s:automation:%s\n' "$RUNTIME" "${BASH_REMATCH[1]}"
  elif [[ "$path" =~ /Documents/Codex/([^/]+)/([^/]+) ]]; then
    printf '%s:workspace:%s/%s\n' "$RUNTIME" "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}"
  fi
}

scoped_key() {
  local kind="$1"
  local value="$2"
  if [[ "$value" == *:* ]]; then
    printf '%s\n' "$value"
  else
    printf '%s:%s:%s\n' "$RUNTIME" "$kind" "$value"
  fi
}

if [[ -z "$SOURCE_CHANNEL" ]]; then
  SOURCE_CHANNEL="$(derive_source_channel "$SCOPE_PATH")"
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GRAYMATTER_API_COMMAND="${GRAYMATTER_API_COMMAND:-${SCRIPT_DIR}/graymatter_api.sh}"

is_query_degraded_response() {
  local file="$1"

  if [[ ! -s "$file" ]]; then
    return 1
  fi

  if command -v jq >/dev/null 2>&1; then
    jq -e '
      [
        .error?,
        .message?,
        .classification?,
        .warning?,
        .action?,
        .details?.error?,
        .details?.message?,
        .details?.warning?,
        .details?.action?
      ]
      | map(select(type == "string") | ascii_downcase)
      | any(test("transaction timeout|timeout expired|timed out|insufficient_quota|quota exhausted|embeddings? failed|embedding provider quota"))
    ' "$file" >/dev/null 2>&1 && return 0
  fi

  grep -Eiq 'transaction timeout|timeout expired|timed out|insufficient_quota|quota exhausted|embeddings? failed|embedding provider quota' "$file"
}

fallback_memoryentry_filter() {
  local list_body="$1"

  command -v jq >/dev/null 2>&1 || return 1

  jq -c \
    --arg q "$(printf '%s' "$QUERY" | tr '[:upper:]' '[:lower:]')" \
    --argjson limit "$LIMIT" \
    --arg type "$TYPE" \
    --arg source "$SOURCE_CHANNEL" '
      def entries:
        if type == "array" then .
        elif (.content? | type) == "array" then .content
        elif (.items? | type) == "array" then .items
        elif (.data? | type) == "array" then .data
        elif (.results? | type) == "array" then .results
        elif (.records? | type) == "array" then .records
        else []
        end;
      def tag_text:
        (.tags // [])
        | map(if type == "object" then (.name // .id // "") else tostring end)
        | join(" ");
      def searchable_text:
        [
          .text?,
          .title?,
          .summary?,
          .description?,
          .content?,
          .type?,
          tag_text
        ]
        | map(select(. != null) | tostring)
        | join(" ")
        | ascii_downcase;
      def query_terms:
        $q
        | gsub("[^a-z0-9_-]+"; " ")
        | split(" ")
        | map(select(length > 2))
        | unique;
      def lexical_score($text):
        query_terms as $terms
        | if ($terms | length) == 0 then
            (if ($text | contains($q)) then 1 else 0 end)
          else
            ($terms | map(. as $term | select($text | contains($term))) | length)
          end;
      entries
      | map(. as $entry | (searchable_text) as $text | $entry + {"_gmLexicalScore": lexical_score($text)})
      | map(select(
          ($type == "" or (.type? == $type))
          and ($source == "" or (.source? == $source) or (.sourceChannel? == $source))
          and ((searchable_text | contains($q)) or (._gmLexicalScore > 0))
        ))
      | sort_by(._gmLexicalScore) | reverse
      | map(del(._gmLexicalScore))
      | .[:$limit]
    ' "$list_body"
}

run_memoryentry_query() {
  "$GRAYMATTER_API_COMMAND" POST /MemoryEntry/query "$BODY"
}

run_memoryentry_timeout_fallback() {
  local list_body

  list_body="$(mktemp "${TMPDIR:-/tmp}/gm-query-memoryentry-list.XXXXXX")"
  trap 'rm -f "$list_body"' RETURN

  "$GRAYMATTER_API_COMMAND" GET /MemoryEntry >"$list_body"
  fallback_memoryentry_filter "$list_body"
}

format_response() {
  local response_file="$1"

  if [[ "$OUTPUT_FORMAT" == "json" ]]; then
    cat "$response_file"
    return 0
  fi

  command -v jq >/dev/null 2>&1 || {
    echo "gm-query: --brief/--english requires jq" >&2
    return 1
  }

  jq -r --arg query "$QUERY" --argjson textMax "$TEXT_MAX" '
    def entries:
      if type == "array" then .
      elif (.content? | type) == "array" then .content
      elif (.items? | type) == "array" then .items
      elif (.data? | type) == "array" then .data
      elif (.results? | type) == "array" then .results
      elif (.records? | type) == "array" then .records
      else []
      end;
    def compact_text:
      tostring
      | gsub("[\\r\\n\\t]+"; " ")
      | gsub("  +"; " ")
      | gsub("^\\s+|\\s+$"; "");
    def bounded:
      compact_text
      | if length > $textMax then .[0:($textMax - 3)] + "..." else . end;
    def tag_names:
      (.tags // [])
      | map(if type == "object" then (.name // .id // "") else tostring end)
      | map(select(length > 0))
      | unique
      | join(",");
    entries as $entries
    | "GrayMatter returned \($entries | length) matching memory " + (if ($entries | length) == 1 then "entry" else "entries" end) + " for: " + $query,
      (
        $entries[]
        | "- [" + (.type // "unknown") + "] "
          + ((.text // .title // .summary // .description // .content // "") | bounded)
          + " (id=" + ((.id // "") | tostring)
          + ", source=" + ((.sourceChannel // .source // "") | tostring)
          + (if ((tag_names | length) > 0) then ", tags=" + tag_names else "" end)
          + ")"
      )
  ' "$response_file"
}

if [[ -n "$TYPE" && -n "$SOURCE_CHANNEL" ]]; then
  BODY="$(jq -nc --arg q "$QUERY" --argjson maxResults "$LIMIT" --arg type "$TYPE" --arg source "$SOURCE_CHANNEL" '{q:$q,maxResults:$maxResults,type:$type,source:$source}')"
elif [[ -n "$TYPE" ]]; then
  BODY="$(jq -nc --arg q "$QUERY" --argjson maxResults "$LIMIT" --arg type "$TYPE" '{q:$q,maxResults:$maxResults,type:$type}')"
elif [[ -n "$SOURCE_CHANNEL" ]]; then
  BODY="$(jq -nc --arg q "$QUERY" --argjson maxResults "$LIMIT" --arg source "$SOURCE_CHANNEL" '{q:$q,maxResults:$maxResults,source:$source}')"
else
  BODY="$(jq -nc --arg q "$QUERY" --argjson maxResults "$LIMIT" '{q:$q,maxResults:$maxResults}')"
fi

QUERY_RESPONSE="$(mktemp "${TMPDIR:-/tmp}/gm-query-response.XXXXXX")"
trap 'rm -f "$QUERY_RESPONSE"' EXIT

if run_memoryentry_query >"$QUERY_RESPONSE"; then
  format_response "$QUERY_RESPONSE"
  exit 0
else
  QUERY_STATUS=$?
fi

cat "$QUERY_RESPONSE" >&2
if [[ -s "$QUERY_RESPONSE" ]]; then
  echo >&2
fi

if [[ "${GRAYMATTER_QUERY_TIMEOUT_FALLBACK:-true}" == "true" ]] && is_query_degraded_response "$QUERY_RESPONSE"; then
  echo "gm-query: MemoryEntry/query degraded; falling back to MemoryEntry list filtering" >&2
  FALLBACK_RESPONSE="$(mktemp "${TMPDIR:-/tmp}/gm-query-fallback-response.XXXXXX")"
  trap 'rm -f "$QUERY_RESPONSE" "$FALLBACK_RESPONSE"' EXIT
  run_memoryentry_timeout_fallback >"$FALLBACK_RESPONSE"
  format_response "$FALLBACK_RESPONSE"
  exit 0
fi

exit "$QUERY_STATUS"
