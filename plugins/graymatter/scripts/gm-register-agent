#!/usr/bin/env bash
set -euo pipefail

INSTANCE_ID="${1:-${GRAYMATTER_SWARM_ID:-${HOSTNAME:-openclaw-instance}}}"
AGENT_NAME="${2:-${GRAYMATTER_AGENT_NAME:-${OPENCLAW_AGENT_NAME:-Valor}}}"
ROLE_LABEL="${3:-${GRAYMATTER_AGENT_ROLE:-openclaw-server}}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
METADATA="$(jq -nc \
  --arg name "$AGENT_NAME" \
  --arg role "$ROLE_LABEL" \
  --arg host "$(hostname 2>/dev/null || echo unknown-host)" \
  --arg platform "OpenClaw" \
  --arg memory "GrayMatter" \
  '{name:$name,role:$role,host:$host,platform:$platform,primaryMemory:$memory}')"

PAYLOAD="$(jq -nc --arg instanceId "$INSTANCE_ID" --arg metadata "$METADATA" '{instanceId:$instanceId,metadata:$metadata}')"

"${SCRIPT_DIR}/graymatter_api.sh" POST /swarm-ops/register "$PAYLOAD"
