#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CAPABILITY_MANIFEST=""
OUT=""

usage() {
  cat <<'EOF'
Usage:
  scripts/gm-release-evidence [--capability-manifest PATH] [--out PATH]

Builds a content-free OmegaRAG source-to-installed release evidence bundle.
The strongest possible decision is ELIGIBLE_FOR_HUMAN_REVIEW; this tool never
authorizes claims, merge, release, or production deployment.
EOF
}

fail() {
  printf 'gm-release-evidence failed: %s\n' "$*" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || fail "missing required command: $1"
}

sha256_file() {
  shasum -a 256 "$1" | awk '{print $1}'
}

canonical_output_path() {
  local path="$1"
  local parent
  parent="$(dirname "$path")"
  mkdir -p "$parent"
  parent="$(cd "$parent" && pwd -P)"
  printf '%s/%s\n' "$parent" "$(basename "$path")"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --capability-manifest)
      shift
      CAPABILITY_MANIFEST="${1:-}"
      [[ -n "$CAPABILITY_MANIFEST" ]] || fail "--capability-manifest requires a path"
      ;;
    --out)
      shift
      OUT="${1:-}"
      [[ -n "$OUT" ]] || fail "--out requires a path"
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      fail "unknown option: $1"
      ;;
  esac
  shift
done

require_command jq
require_command shasum

if [[ -n "$OUT" ]]; then
  OUT="$(canonical_output_path "$OUT")"
fi
if [[ -n "$CAPABILITY_MANIFEST" && -n "$OUT" && -e "$CAPABILITY_MANIFEST" ]]; then
  capability_parent="$(cd "$(dirname "$CAPABILITY_MANIFEST")" && pwd -P)"
  capability_path="$capability_parent/$(basename "$CAPABILITY_MANIFEST")"
  [[ "$OUT" != "$capability_path" ]] || fail "--out must not overwrite the capability manifest"
fi

POLICY="$ROOT/references/contracts/release/graymatter_omegarag_release_policy_v1.json"
[[ -f "$POLICY" ]] || fail "release policy is missing"
jq -e '.schemaVersion == "graymatter-omegarag-release-policy/v1"' "$POLICY" >/dev/null \
  || fail "release policy is invalid"

tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/gm-release-evidence.XXXXXX")"
trap 'rm -rf "$tmp_dir"' EXIT
checks_file="$tmp_dir/checks.jsonl"
contracts_file="$tmp_dir/contracts.jsonl"
blockers_file="$tmp_dir/blockers.txt"
: >"$checks_file"
: >"$contracts_file"
: >"$blockers_file"

add_check() {
  local id="$1"
  local status="$2"
  local summary="$3"
  local details="${4-}"
  [[ -n "$details" ]] || details='{}'
  case "$status" in
    PASS|FAIL|NOT_APPLICABLE) ;;
    *) fail "invalid check status for $id: $status" ;;
  esac
  jq -cn \
    --arg id "$id" \
    --arg status "$status" \
    --arg summary "$summary" \
    --argjson details "$details" \
    '{id:$id,status:$status,summary:$summary,details:$details}' >>"$checks_file"
  if [[ "$status" == "FAIL" ]]; then
    printf '%s\n' "$id" >>"$blockers_file"
  fi
}

plugin_manifest="$ROOT/.codex-plugin/plugin.json"
clawhub_manifest="$ROOT/clawhub.json"
mcp_manifest="$ROOT/mcp-server/package.json"
[[ -f "$plugin_manifest" && -f "$clawhub_manifest" && -f "$mcp_manifest" ]] \
  || fail "version manifests are missing"

plugin_version="$(jq -er '.version | strings | select(length > 0)' "$plugin_manifest")" \
  || fail "plugin version is invalid"
base_version="${plugin_version%%+codex.*}"
clawhub_version="$(jq -er '.version | strings | select(length > 0)' "$clawhub_manifest")" \
  || fail "ClawHub version is invalid"
mcp_version="$(jq -er '.version | strings | select(length > 0)' "$mcp_manifest")" \
  || fail "MCP version is invalid"
marketplace_version=""
marketplace_manifest="$ROOT/plugins/graymatter/.codex-plugin/plugin.json"
if [[ -f "$marketplace_manifest" ]]; then
  marketplace_version="$(jq -er '.version | strings | select(length > 0)' "$marketplace_manifest")" \
    || fail "marketplace plugin version is invalid"
fi

version_details="$(jq -cn \
  --arg pluginVersion "$plugin_version" \
  --arg baseVersion "$base_version" \
  --arg marketplaceVersion "$marketplace_version" \
  --arg clawhubVersion "$clawhub_version" \
  --arg mcpVersion "$mcp_version" '
    {
      pluginVersion:$pluginVersion,
      baseVersion:$baseVersion,
      marketplaceVersion:($marketplaceVersion | if length > 0 then . else null end),
      clawhubVersion:$clawhubVersion,
      mcpVersion:$mcpVersion
    }
  ')"
versions_valid=true
[[ "$base_version" == "$clawhub_version" && "$base_version" == "$mcp_version" ]] || versions_valid=false
if [[ -n "$marketplace_version" ]]; then
  [[ "$marketplace_version" == "$base_version" || "$marketplace_version" == "$base_version"+codex.* ]] \
    || versions_valid=false
fi
if [[ "$versions_valid" == true ]]; then
  add_check "version-alignment" "PASS" "Plugin, ClawHub, and MCP versions share one base release." "$version_details"
else
  add_check "version-alignment" "FAIL" "Release surface versions do not share one base release." "$version_details"
fi

source_revision=""
revision_source=""
if [[ -f "$ROOT/.graymatter-source-rev" ]]; then
  source_revision="$(tr -d '[:space:]' <"$ROOT/.graymatter-source-rev")"
  revision_source="installed-source-marker"
elif git -C "$ROOT" rev-parse --verify HEAD >/dev/null 2>&1; then
  source_revision="$(git -C "$ROOT" rev-parse HEAD)"
  revision_source="git-head"
fi
if [[ "$source_revision" =~ ^[0-9a-f]{40,64}$ ]]; then
  add_check "source-revision" "PASS" "The evidence is bound to a source revision." \
    "$(jq -cn --arg revision "$source_revision" --arg source "$revision_source" '{revision:$revision,source:$source}')"
else
  add_check "source-revision" "FAIL" "No valid Git or installed source revision was found."
fi

archive_details='{}'
if [[ "$plugin_version" == *+codex.* ]]; then
  add_check "deterministic-package" "NOT_APPLICABLE" \
    "Marketplace plugin packages are validated by their installed source marker and packaged files."
elif [[ -f "$ROOT/graymatter.skill" ]]; then
  archive_details="$(jq -cn --arg file "graymatter.skill" --arg sha256 "$(sha256_file "$ROOT/graymatter.skill")" \
    '{file:$file,sha256:$sha256}')"
  add_check "deterministic-package" "PASS" "The standalone archive is present and hash-bound." "$archive_details"
else
  add_check "deterministic-package" "FAIL" "The standalone archive is missing for a non-marketplace release surface."
fi

submission_manifest="$ROOT/openai-app/submission-manifest.json"
submission_target=""
if [[ -f "$submission_manifest" ]]; then
  submission_target="$(jq -er '(.submissionChecklistPath // .submissionChecklist) | strings | select(length > 0)' "$submission_manifest" 2>/dev/null || true)"
fi
submission_details="$(jq -cn --arg manifest "openai-app/submission-manifest.json" \
  --arg target "$(basename "${submission_target:-missing}")" '{manifest:$manifest,target:$target}')"
if [[ -n "$submission_target" && "$submission_target" == "$(basename "$submission_target")" \
  && -f "$ROOT/$submission_target" ]]; then
  submission_details="$(jq -cn --arg manifest "openai-app/submission-manifest.json" \
    --arg manifestSha256 "$(sha256_file "$submission_manifest")" \
    --arg target "$submission_target" --arg targetSha256 "$(sha256_file "$ROOT/$submission_target")" \
    '{manifest:$manifest,manifestSha256:$manifestSha256,target:$target,targetSha256:$targetSha256}')"
  add_check "submission-checklist-target" "PASS" "The submission manifest resolves to a packaged checklist." "$submission_details"
else
  add_check "submission-checklist-target" "FAIL" "The submission checklist target is missing or escapes the package root." "$submission_details"
fi

if [[ -f "$ROOT/SUBMISSION_CHECKLIST.md" && -f "$ROOT/plugins/graymatter/SUBMISSION_CHECKLIST.md" ]]; then
  checklist_details="$(jq -cn --arg sha256 "$(sha256_file "$ROOT/SUBMISSION_CHECKLIST.md")" '{sha256:$sha256}')"
  if cmp -s "$ROOT/SUBMISSION_CHECKLIST.md" "$ROOT/plugins/graymatter/SUBMISSION_CHECKLIST.md"; then
    add_check "submission-checklist-parity" "PASS" "Root and marketplace submission checklists match." "$checklist_details"
  else
    add_check "submission-checklist-parity" "FAIL" "Root and marketplace submission checklists differ."
  fi
elif [[ -f "$ROOT/SUBMISSION_CHECKLIST.md" ]]; then
  add_check "submission-checklist-parity" "NOT_APPLICABLE" \
    "This packaged surface contains one submission checklist." \
    "$(jq -cn --arg sha256 "$(sha256_file "$ROOT/SUBMISSION_CHECKLIST.md")" '{sha256:$sha256}')"
else
  add_check "submission-checklist-parity" "FAIL" "The packaged submission checklist is missing."
fi

required_contract_count="$(jq '.requiredContracts | length' "$POLICY")"
valid_contract_count=0
while IFS=$'\t' read -r contract_id contract_path; do
  contract_status="FAIL"
  contract_hash=""
  if [[ "$contract_path" == references/* && -f "$ROOT/$contract_path" ]] \
    && jq -e . "$ROOT/$contract_path" >/dev/null 2>&1; then
    contract_status="PASS"
    contract_hash="$(sha256_file "$ROOT/$contract_path")"
    valid_contract_count=$((valid_contract_count + 1))
  fi
  jq -cn --arg id "$contract_id" --arg path "$contract_path" --arg status "$contract_status" \
    --arg sha256 "$contract_hash" \
    '{id:$id,path:$path,status:$status,sha256:($sha256 | if length > 0 then . else null end)}' >>"$contracts_file"
done < <(jq -r '.requiredContracts[] | [.id,.path] | @tsv' "$POLICY")
if [[ "$valid_contract_count" -eq "$required_contract_count" ]]; then
  add_check "contract-set" "PASS" "Every required portable contract is present, valid JSON, and hash-bound." \
    "$(jq -s '{count:length}' "$contracts_file")"
else
  add_check "contract-set" "FAIL" "One or more required portable contracts is missing or invalid." \
    "$(jq -s '{count:length,failed:map(select(.status == "FAIL") | .id)}' "$contracts_file")"
fi

if [[ -f "$ROOT/plugins/graymatter/scripts/gm-release-evidence" ]]; then
  parity_failures=()
  for relative in \
    scripts/gm-release-evidence \
    references/contracts/release/graymatter_omegarag_release_policy_v1.json \
    docs/omegarag-release-evidence.md; do
    [[ -f "$ROOT/plugins/graymatter/$relative" ]] || {
      parity_failures+=("$relative")
      continue
    }
    cmp -s "$ROOT/$relative" "$ROOT/plugins/graymatter/$relative" || parity_failures+=("$relative")
  done
  if [[ ${#parity_failures[@]} -eq 0 ]]; then
    parity_details="$(jq -cn \
      --arg scriptSha256 "$(sha256_file "$ROOT/scripts/gm-release-evidence")" \
      --arg policySha256 "$(sha256_file "$POLICY")" \
      --arg docsSha256 "$(sha256_file "$ROOT/docs/omegarag-release-evidence.md")" \
      '{scriptSha256:$scriptSha256,policySha256:$policySha256,docsSha256:$docsSha256}')"
    add_check "marketplace-release-parity" "PASS" "Release evidence script, policy, and docs match the marketplace surface." "$parity_details"
  else
    add_check "marketplace-release-parity" "FAIL" "Marketplace release evidence surfaces differ from the root package." \
      "$(jq -cn '$ARGS.positional | {mismatches:.}' --args "${parity_failures[@]}")"
  fi
else
  add_check "marketplace-release-parity" "NOT_APPLICABLE" \
    "This package contains one release evidence surface."
fi

smoke_out="$tmp_dir/smoke.json"
smoke_details='{}'
smoke_valid=false
if [[ -x "$ROOT/scripts/gm-agent-smoke-matrix" ]] \
  && "$ROOT/scripts/gm-agent-smoke-matrix" --mode local --out "$smoke_out" >/dev/null 2>&1 \
  && jq -e . "$smoke_out" >/dev/null 2>&1; then
  smoke_details="$(jq -c '{lane,mode,summary,stages:[.stages[] | {name,status}]}' "$smoke_out")"
  if jq -e --argjson policy "$(jq -c . "$POLICY")" '
      .summary.fail == 0
      and ([ $policy.requiredSmokeStages[] as $required
        | any(.stages[]; .name == $required and .status == "pass") ] | all)
      and ([ $policy.manualSmokeStages[] as $manual
        | any(.stages[]; .name == $manual and .status == "manual_required") ] | all)
    ' "$smoke_out" >/dev/null; then
    smoke_valid=true
  fi
fi
if [[ "$smoke_valid" == true ]]; then
  add_check "local-agent-smoke" "PASS" "Required local stages pass and approval-gated stages remain manual." "$smoke_details"
else
  add_check "local-agent-smoke" "FAIL" "The local agent smoke matrix did not satisfy the versioned release policy." "$smoke_details"
fi

capability_status="MISSING"
capability_reason="No capability manifest was supplied."
capability_projection='null'
if [[ -n "$CAPABILITY_MANIFEST" && -f "$CAPABILITY_MANIFEST" ]]; then
  manifest_json=""
  if manifest_json="$(jq -cse '
      if length == 1 and (.[0] | type == "object") then .[0]
      else error("expected exactly one JSON object") end
    ' "$CAPABILITY_MANIFEST" 2>/dev/null)"; then
    now_epoch="$(date -u +%s)"
    if jq -e --argjson now "$now_epoch" '
        def utc_epoch:
          sub("\\+00:00$"; "Z")
          | sub("\\.[0-9]+Z$"; "Z")
          | fromdateiso8601;
        def evidence_tier:
          IN("AUTHENTICATED_LIVE_READ","AUTHENTICATED_SIGNATURE_CANARY","RUNTIME_COMPONENT_REGISTRATION","CONTRACT_DECLARATION","NONE");
        def evidence_state:
          IN("LIVE_VERIFIED","IMPLEMENTED_UNVERIFIED","DEGRADED","PLANNED","UNAVAILABLE");
        def bounded_strings:
          type == "array" and length <= 32 and all(.[]; type == "string" and length <= 240);
        .manifestVersion == "omegarag-capability-manifest/v1"
        and (.scopeHash | type == "string" and test("^[0-9a-f]{64}$"))
        and (.authorityHash | type == "string" and test("^[0-9a-f]{64}$"))
        and (.checkedAt | type == "string" and utc_epoch <= ($now + 300))
        and (.expiresAt | type == "string" and utc_epoch > $now)
        and (.ttlSeconds | type == "number" and . > 0)
        and (.capabilities | type == "array" and length > 0)
        and (all(.capabilities[];
          ((.capabilityId // .id) | type == "string" and length > 0 and length <= 160)
          and (.state | evidence_state)
          and (.evidenceTier | evidence_tier)
          and (.invocable | type == "boolean")
          and (.liveVerified | type == "boolean")
          and (if .state == "LIVE_VERIFIED" then
            .liveVerified == true
            and (.evidenceExpiresAt | type == "string" and utc_epoch > $now)
          else .liveVerified == false end)
          and ((.lastCheckedAt == null) or (.lastCheckedAt | type == "string" and length <= 64))
          and ((.degradedReason == null) or (.degradedReason | type == "string" and length <= 240))
          and ((.safeNextAction == null) or (.safeNextAction | type == "string" and length <= 240))))
        and (([.capabilities[] | .capabilityId // .id] | unique | length) == (.capabilities | length))
        and ((.subsystems // []) | type == "array")
        and (all((.subsystems // [])[];
          ((.subsystemId // .id) | type == "string" and length > 0 and length <= 160)
          and (.state | evidence_state)
          and (.evidenceTier | evidence_tier)
          and ((.reason == null) or (.reason | type == "string" and length <= 240))
          and ((.safeNextAction == null) or (.safeNextAction | type == "string" and length <= 240))))
        and (.limits | type == "object")
        and (.distributions | type == "object")
        and (.distributions.light | type == "object")
        and (.distributions.cloud | type == "object")
        and (all([.distributions.light,.distributions.cloud][];
          (.displayName | type == "string" and length <= 120)
          and (.evidenceTier | evidence_tier)
          and (.currentRuntimeCompatible | type == "boolean")
          and (.correctnessPath | bounded_strings)
          and (.optionalAccelerators | bounded_strings)
          and (.explicitDifferences | bounded_strings)))
      ' <<<"$manifest_json" >/dev/null 2>&1; then
      capability_status="CURRENT"
      capability_reason="The scoped capability manifest is structurally valid and unexpired."
      capability_projection="$(jq -c '
        def bounded_strings: if type == "array" then map(select(type == "string") | .[0:240])[:32] else [] end;
        def state_counts: reduce .[] as $state
          ({LIVE_VERIFIED:0,IMPLEMENTED_UNVERIFIED:0,DEGRADED:0,PLANNED:0,UNAVAILABLE:0}; .[$state] += 1);
        {
          manifestVersion,
          apiVersion,
          environment,
          scopeHash,
          schemaVersion,
          policyVersion,
          authorityHash,
          checkedAt,
          expiresAt,
          ttlSeconds,
          stateCounts:([.capabilities[].state] | state_counts),
          capabilities:[.capabilities[] | {
            id:((.capabilityId // .id)[0:160]),
            state,
            evidenceTier,
            invocable,
            liveVerified,
            lastCheckedAt,
            evidenceExpiresAt,
            degradedReason:(.degradedReason // "" | tostring | .[0:240] | if length > 0 then . else null end),
            safeNextAction:(.safeNextAction // "" | tostring | .[0:240] | if length > 0 then . else null end)
          }],
          subsystems:[(.subsystems // [])[] | {
            id:(.subsystemId // .id // "" | tostring | .[0:160]),
            state,
            evidenceTier,
            lastCheckedAt,
            reason:(.reason // "" | tostring | .[0:240] | if length > 0 then . else null end),
            safeNextAction:(.safeNextAction // "" | tostring | .[0:240] | if length > 0 then . else null end)
          }],
          limits:(.limits | {
            defaultTopK,maxTopK,maxAdaptiveRetrievalSteps,minContextChars,defaultContextChars,maxContextChars,
            capabilityTtlSeconds,maxLatencyMs,maxCredits,maxContextTokens,maxGraphHops,maxProviderCalls,
            maxCandidates,maxEvidenceBytes,maxParallelFanout,maxGraphNodes,maxGraphEdges,maxAsyncRunDurationMs,
            maxAsyncAttempts,retryInitialBackoffMs,retryBackoffMultiplier,retryMaxBackoffMs,
            circuitFailureThreshold,circuitOpenSeconds
          } | with_entries(select(.value != null and (.value | type == "number")))),
          distributions:(.distributions | with_entries(
            select(.key == "light" or .key == "cloud")
            | .value |= {
              displayName:(.displayName // "" | tostring | .[0:120]),
              evidenceTier,
              currentRuntimeCompatible,
              correctnessPath:(.correctnessPath | bounded_strings),
              optionalAccelerators:(.optionalAccelerators | bounded_strings),
              explicitDifferences:(.explicitDifferences | bounded_strings)
            }))
        }
      ' <<<"$manifest_json")"
      if jq -e '
          any(.capabilities[]; .state == "DEGRADED" or .state == "UNAVAILABLE")
          or any(.subsystems[]; .state == "DEGRADED" or .state == "UNAVAILABLE")
        ' <<<"$capability_projection" >/dev/null; then
        capability_status="BLOCKED"
        capability_reason="The current manifest contains degraded or unavailable capability evidence."
      fi
    else
      capability_status="INVALID_OR_EXPIRED"
      capability_reason="The capability manifest is invalid, unscoped, incomplete, or expired."
    fi
  else
    capability_status="INVALID_OR_EXPIRED"
    capability_reason="The capability input is not exactly one JSON object."
  fi
elif [[ -n "$CAPABILITY_MANIFEST" ]]; then
  capability_status="INVALID_OR_EXPIRED"
  capability_reason="The requested capability manifest does not exist."
fi

capability_details="$(jq -cn --arg status "$capability_status" --arg reason "$capability_reason" \
  --arg file "$(basename "${CAPABILITY_MANIFEST:-not-supplied}")" \
  --argjson manifest "$capability_projection" '{status:$status,reason:$reason,file:$file,manifest:$manifest}')"
if [[ "$capability_status" == "CURRENT" ]]; then
  add_check "capability-manifest" "PASS" "$capability_reason" "$capability_details"
else
  add_check "capability-manifest" "FAIL" "$capability_reason" "$capability_details"
fi

decision="HOLD"
if [[ ! -s "$blockers_file" ]]; then
  decision="ELIGIBLE_FOR_HUMAN_REVIEW"
fi

generated_at="$(date -u +%FT%TZ)"
result="$(jq -n \
  --arg schemaVersion "graymatter-omegarag-release-evidence/v1" \
  --arg generatedAt "$generated_at" \
  --arg decision "$decision" \
  --arg sourceRevision "$source_revision" \
  --arg revisionSource "$revision_source" \
  --argjson versions "$version_details" \
  --argjson archive "$archive_details" \
  --argjson contracts "$(jq -s . "$contracts_file")" \
  --argjson checks "$(jq -s . "$checks_file")" \
  --argjson limitations "$(jq -c '.knownLimitations' "$POLICY")" '
    {
      schemaVersion:$schemaVersion,
      generatedAt:$generatedAt,
      decision:$decision,
      authorizations:{
        releaseAuthorized:false,
        claimPromotionAuthorized:false,
        mergeAuthorized:false,
        productionDeploymentAuthorized:false
      },
      source:{revision:$sourceRevision,revisionSource:$revisionSource},
      versions:$versions,
      packageArchive:$archive,
      contracts:$contracts,
      checks:$checks,
      knownLimitations:$limitations
    }
  ')"

if [[ -n "$OUT" ]]; then
  printf '%s\n' "$result" >"$OUT"
else
  printf '%s\n' "$result"
fi
