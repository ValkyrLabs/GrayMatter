#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
REPO_URL="${GRAYMATTER_PLUGIN_REPO:-https://github.com/ValkyrLabs/GrayMatter.git}"
BRANCH="${GRAYMATTER_PLUGIN_BRANCH:-main}"
STATE_DIR="${GRAYMATTER_STATE_DIR:-${HOME:-$ROOT_DIR}/.graymatter}"
STATE_FILE="${GRAYMATTER_SELF_UPDATE_STATE:-${STATE_DIR}/plugin-update.json}"
INTERVAL_SECONDS="${GRAYMATTER_SELF_UPDATE_INTERVAL_SECONDS:-604800}"
MODE="${1:-maybe}"
SELF_UPDATE_TMP=""

usage() {
  cat <<'EOF'
Usage: gm-self-update [maybe|check|force]

Keeps the installed GrayMatter repo/plugin aligned with the source-of-truth
GitHub repository. Normal startup should use `maybe`; activation/recovery may
use `force` when auth or transport is suspicious.
EOF
}

if [[ "$MODE" == "-h" || "$MODE" == "--help" ]]; then
  usage
  exit 0
fi

have() {
  command -v "$1" >/dev/null 2>&1
}

log() {
  [[ "${GRAYMATTER_SELF_UPDATE_QUIET:-false}" == "true" ]] && return 0
  printf '%s\n' "$*" >&2
}

now_epoch() {
  date +%s
}

json_get_number() {
  local file="$1"
  local key="$2"
  [[ -f "$file" ]] || {
    printf '0\n'
    return 0
  }
  have jq || {
    printf '0\n'
    return 0
  }
  jq -r --arg key "$key" '.[$key] // 0' "$file" 2>/dev/null || printf '0\n'
}

record_state() {
  local status="$1"
  local local_rev="${2:-}"
  local remote_rev="${3:-}"
  mkdir -p "$STATE_DIR"
  mkdir -p "$(dirname "$STATE_FILE")"
  if have jq; then
    jq -n \
      --arg checkedAt "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
      --argjson checkedAtEpoch "$(now_epoch)" \
      --arg status "$status" \
      --arg repo "$REPO_URL" \
      --arg branch "$BRANCH" \
      --arg root "$ROOT_DIR" \
      --arg localRev "$local_rev" \
      --arg remoteRev "$remote_rev" \
      '{checkedAt:$checkedAt, checkedAtEpoch:$checkedAtEpoch, status:$status, repo:$repo, branch:$branch, root:$root, localRev:$localRev, remoteRev:$remoteRev}' \
      >"$STATE_FILE"
  else
    printf '{"checkedAtEpoch":%s,"status":"%s","repo":"%s","branch":"%s","root":"%s","localRev":"%s","remoteRev":"%s"}\n' \
      "$(now_epoch)" "$status" "$REPO_URL" "$BRANCH" "$ROOT_DIR" "$local_rev" "$remote_rev" >"$STATE_FILE"
  fi
}

should_check() {
  [[ "$MODE" == "force" || "${GRAYMATTER_FORCE_SELF_UPDATE:-false}" == "true" ]] && return 0
  [[ "$MODE" == "check" ]] && return 0
  [[ "$MODE" == "maybe" ]] || {
    usage >&2
    exit 2
  }

  local last_checked elapsed
  last_checked="$(json_get_number "$STATE_FILE" checkedAtEpoch)"
  elapsed=$(( $(now_epoch) - last_checked ))
  [[ "$elapsed" -ge "$INTERVAL_SECONDS" ]]
}

remote_head() {
  git ls-remote "$REPO_URL" "refs/heads/${BRANCH}" 2>/dev/null | awk 'NR==1 {print $1}'
}

working_tree_dirty() {
  [[ -n "$(git -C "$ROOT_DIR" status --porcelain 2>/dev/null)" ]]
}

update_git_checkout() {
  local remote_rev="$1"
  local local_rev=""
  local_rev="$(git -C "$ROOT_DIR" rev-parse HEAD 2>/dev/null || true)"

  if [[ -z "$remote_rev" ]]; then
    record_state "remote-unavailable" "$local_rev" ""
    log "GrayMatter plugin update check skipped: source repo unreachable"
    return 0
  fi

  if [[ "$local_rev" == "$remote_rev" ]]; then
    record_state "up-to-date" "$local_rev" "$remote_rev"
    log "GrayMatter plugin ready: up to date"
    return 0
  fi

  if working_tree_dirty; then
    record_state "update-available-dirty" "$local_rev" "$remote_rev"
    log "GrayMatter update available but checkout has local changes; leaving files untouched"
    return 0
  fi

  log "GrayMatter plugin update available; downloading latest source"
  git -C "$ROOT_DIR" fetch --quiet origin "$BRANCH"
  git -C "$ROOT_DIR" merge --ff-only --quiet "origin/${BRANCH}"
  local_rev="$(git -C "$ROOT_DIR" rev-parse HEAD)"
  record_state "updated" "$local_rev" "$remote_rev"
  log "GrayMatter plugin ready: updated to ${local_rev}"
}

update_packaged_install() {
  local remote_rev="$1"
  local local_rev=""
  cleanup_tmp() {
    [[ -z "$SELF_UPDATE_TMP" ]] || rm -rf "$SELF_UPDATE_TMP"
  }
  trap cleanup_tmp EXIT

  local_rev="$(cat "$ROOT_DIR/.graymatter-source-rev" 2>/dev/null || true)"
  if [[ -z "$remote_rev" ]]; then
    record_state "remote-unavailable" "$local_rev" ""
    log "GrayMatter plugin update check skipped: source repo unreachable"
    return 0
  fi

  if [[ "$local_rev" == "$remote_rev" ]]; then
    record_state "up-to-date" "$local_rev" "$remote_rev"
    log "GrayMatter plugin ready: up to date"
    return 0
  fi

  have rsync || {
    record_state "update-available-rsync-missing" "$local_rev" "$remote_rev"
    log "GrayMatter update available but rsync is missing; leaving packaged install untouched"
    return 0
  }

  SELF_UPDATE_TMP="$(mktemp -d "${TMPDIR:-/tmp}/graymatter-self-update.XXXXXX")"
  log "GrayMatter plugin update available; downloading plugin"
  git clone --quiet --depth 1 --branch "$BRANCH" "$REPO_URL" "$SELF_UPDATE_TMP/repo"
  rsync -a --delete \
    --exclude '.git/' \
    --exclude 'dist/' \
    --exclude 'memory/' \
    --exclude 'tmp/' \
    --exclude '.graymatter-light/' \
    "$SELF_UPDATE_TMP/repo/" "$ROOT_DIR/"
  printf '%s\n' "$remote_rev" >"$ROOT_DIR/.graymatter-source-rev"
  record_state "updated" "$remote_rev" "$remote_rev"
  log "GrayMatter plugin ready: updated to ${remote_rev}"
}

if ! should_check; then
  log "GrayMatter plugin ready: update check not due"
  exit 0
fi

have git || {
  record_state "git-missing" "" ""
  log "GrayMatter plugin update check skipped: git is not installed"
  exit 0
}

remote_rev="$(remote_head || true)"
if git -C "$ROOT_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  update_git_checkout "$remote_rev"
else
  update_packaged_install "$remote_rev"
fi
