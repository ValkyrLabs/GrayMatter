#!/usr/bin/env bash
set -euo pipefail

TYPE="${1:-}"
TEXT="${2:-}"

if [[ -z "$TYPE" || -z "$TEXT" ]]; then
  echo "Usage: gm-write <decision|todo|context|artifact|preference> <text> [sourceChannel] [comma-separated-tags] [--scope-path path] [--workspace-key key] [--chat-key key] [--session-key key] [--automation-id id] [--artifact-path path] [--user user]" >&2
  exit 1
fi

shift 2

SOURCE_CHANNEL="openclaw"
SOURCE_CHANNEL_EXPLICIT=0
TAGS_RAW=""
if [[ $# -gt 0 && "${1:-}" != --* ]]; then
  SOURCE_CHANNEL="$1"
  SOURCE_CHANNEL_EXPLICIT=1
  shift
fi
if [[ $# -gt 0 && "${1:-}" != --* ]]; then
  TAGS_RAW="$1"
  shift
fi

SCOPE=""
RUNTIME="codex"
USER_NAME=""
WORKSPACE_KEY=""
CHAT_KEY=""
SESSION_KEY=""
AUTOMATION_ID=""
ARTIFACT_PATH=""
SCOPE_PATH=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --scope)
      SCOPE="${2:-}"
      shift 2
      ;;
    --runtime)
      RUNTIME="${2:-}"
      shift 2
      ;;
    --user)
      USER_NAME="${2:-}"
      shift 2
      ;;
    --workspace-key)
      WORKSPACE_KEY="${2:-}"
      shift 2
      ;;
    --chat-key)
      CHAT_KEY="${2:-}"
      shift 2
      ;;
    --session-key)
      SESSION_KEY="${2:-}"
      shift 2
      ;;
    --automation-id)
      AUTOMATION_ID="${2:-}"
      shift 2
      ;;
    --artifact-path|--path|--scope-path)
      SCOPE_PATH="${2:-}"
      if [[ "$1" == "--artifact-path" ]]; then
        ARTIFACT_PATH="${2:-}"
      fi
      shift 2
      ;;
    --source-channel)
      SOURCE_CHANNEL="${2:-}"
      SOURCE_CHANNEL_EXPLICIT=1
      shift 2
      ;;
    --tags)
      TAGS_RAW="${2:-}"
      shift 2
      ;;
    *)
      echo "Unknown gm-write option: $1" >&2
      exit 1
      ;;
  esac
done

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

queue_fallback() {
  local reason="$1"
  local chars="${#TEXT}"
  if [[ -x "${SCRIPT_DIR}/gm-fallback-append" ]]; then
    "${SCRIPT_DIR}/gm-fallback-append" "$TYPE" "$TEXT" "$SOURCE_CHANNEL" "$reason" >/dev/null 2>&1 || true
    echo "Write failed, queued fallback payload in memory/graymatter-fallback.json (chars=${chars})" >&2
  fi
}

preflight_write_state() {
  [[ "${GRAYMATTER_GM_WRITE_PREFLIGHT:-true}" == "false" ]] && return 0
  [[ -x "${SCRIPT_DIR}/gm-status" ]] || return 0

  local status_output=""
  status_output="$(GM_STATUS_FORMAT=kv "${SCRIPT_DIR}/gm-status" 2>/dev/null)" || return 0

  local auth_state=""
  local token_state=""
  local memory_layer=""
  auth_state="$(awk -F= '$1 == "graymatter_auth" {print $2; exit}' <<<"$status_output")"
  token_state="$(awk -F= '$1 == "graymatter_token_state" {print $2; exit}' <<<"$status_output")"
  memory_layer="$(awk -F= '$1 == "memory_layer" {print $2; exit}' <<<"$status_output")"

  if [[ "$auth_state" == *":read_only"* || "$token_state" == "read_only" ]]; then
    echo "gm-write cannot write with read-only GrayMatter auth (auth=${auth_state:-unknown}, token=${token_state:-unknown})." >&2
    echo "Use a write-capable VALKYR_AUTH token or run scripts/gm-login with an account that can write MemoryEntry." >&2
    queue_fallback "gm-write preflight blocked read-only auth"
    exit 23
  fi

  if [[ -n "$memory_layer" && "$memory_layer" != "ready" ]]; then
    echo "gm-write cannot write while GrayMatter memory_layer=${memory_layer}." >&2
    echo "Run scripts/gm-status and scripts/gm-doctor --quick, then retry or replay with scripts/gm-replay-deferred." >&2
    queue_fallback "gm-write preflight blocked memory_layer=${memory_layer}"
    exit 24
  fi
}

derive_scope_from_path() {
  local path="$1"
  if [[ "$path" =~ \.codex/automations/([^/]+) ]]; then
    printf 'automation\n'
  elif [[ "$path" =~ /Documents/Codex/([^/]+)/([^/]+) ]]; then
    printf 'workspace\n'
  fi
}

derive_source_channel() {
  local path="$1"
  if [[ -n "$CHAT_KEY" ]]; then
    scoped_key chat "$CHAT_KEY"
  elif [[ -n "$SESSION_KEY" ]]; then
    scoped_key session "$SESSION_KEY"
  elif [[ -n "$AUTOMATION_ID" ]]; then
    scoped_key automation "$AUTOMATION_ID"
  elif [[ -n "$WORKSPACE_KEY" ]]; then
    scoped_key workspace "$WORKSPACE_KEY"
  elif [[ "$path" =~ \.codex/automations/([^/]+) ]]; then
    printf '%s:automation:%s\n' "$RUNTIME" "${BASH_REMATCH[1]}"
  elif [[ "$path" =~ /Documents/Codex/([^/]+)/([^/]+) ]]; then
    printf '%s:workspace:%s/%s\n' "$RUNTIME" "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}"
  fi
}

scoped_key() {
  local kind="$1"
  local value="$2"
  if [[ "$value" == *:* ]]; then
    printf '%s\n' "$value"
  else
    printf '%s:%s:%s\n' "$RUNTIME" "$kind" "$value"
  fi
}

derive_automation_id_from_path() {
  local path="$1"
  if [[ "$path" =~ \.codex/automations/([^/]+) ]]; then
    printf '%s\n' "${BASH_REMATCH[1]}"
  fi
}

derive_workspace_key_from_path() {
  local path="$1"
  if [[ "$path" =~ /Documents/Codex/([^/]+)/([^/]+) ]]; then
    printf '%s/%s\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}"
  fi
}

if [[ -n "$SCOPE_PATH" && -z "$ARTIFACT_PATH" ]]; then
  ARTIFACT_PATH="$SCOPE_PATH"
fi
if [[ -n "$SCOPE_PATH" && -z "$SCOPE" ]]; then
  SCOPE="$(derive_scope_from_path "$SCOPE_PATH")"
fi
if [[ -n "$SCOPE_PATH" && -z "$AUTOMATION_ID" ]]; then
  AUTOMATION_ID="$(derive_automation_id_from_path "$SCOPE_PATH")"
fi
if [[ -n "$SCOPE_PATH" && -z "$WORKSPACE_KEY" ]]; then
  WORKSPACE_KEY="$(derive_workspace_key_from_path "$SCOPE_PATH")"
fi
if [[ "$SOURCE_CHANNEL_EXPLICIT" == "0" ]]; then
  DERIVED_SOURCE_CHANNEL="$(derive_source_channel "$SCOPE_PATH")"
  if [[ -n "$DERIVED_SOURCE_CHANNEL" ]]; then
    SOURCE_CHANNEL="$DERIVED_SOURCE_CHANNEL"
  fi
fi

SCOPE_METADATA="$(jq -nc \
  --arg scope "$SCOPE" \
  --arg runtime "$RUNTIME" \
  --arg user "$USER_NAME" \
  --arg workspaceKey "$WORKSPACE_KEY" \
  --arg chatKey "$CHAT_KEY" \
  --arg sessionKey "$SESSION_KEY" \
  --arg automationId "$AUTOMATION_ID" \
  --arg artifactPath "$ARTIFACT_PATH" \
  --arg sourceChannel "$SOURCE_CHANNEL" \
  '{
    scope:$scope,
    runtime:$runtime,
    user:$user,
    workspaceKey:$workspaceKey,
    chatKey:$chatKey,
    sessionKey:$sessionKey,
    automationId:$automationId,
    artifactPath:$artifactPath,
    sourceChannel:$sourceChannel
  } | with_entries(select(.value != ""))')"

if [[ -n "$TAGS_RAW" ]]; then
  PAYLOAD="$(jq -nc --arg type "$TYPE" --arg text "$TEXT" --arg sourceChannel "$SOURCE_CHANNEL" --argjson metadata "$SCOPE_METADATA" --arg tagsRaw "$TAGS_RAW" '
    def clean_tags:
      split(",")
      | map(gsub("^\\s+|\\s+$";""))
      | map(select(length > 0))
      | map(ascii_downcase | gsub("\\s+";"-"))
      | unique
      | map({name:., type:"keyword"});
    {
      type:$type,
      text:$text,
      source:$sourceChannel,
      sourceChannel:$sourceChannel,
      tags:($tagsRaw | clean_tags)
    }
    + (if ($metadata | length) > 0 then {metadata:($metadata | tojson)} else {} end)
  ')"
else
  PAYLOAD="$(jq -nc --arg type "$TYPE" --arg text "$TEXT" --arg sourceChannel "$SOURCE_CHANNEL" --argjson metadata "$SCOPE_METADATA" '
    {
      type:$type,
      text:$text,
      source:$sourceChannel,
      sourceChannel:$sourceChannel
    }
    + (if ($metadata | length) > 0 then {metadata:($metadata | tojson)} else {} end)
  ')"
fi

PAYLOAD="$(jq 'del(.id,.ownerId,.ownerID,.createdDate,.keyHash,.lastAccessedById,.lastAccessedDate,.lastModifiedById,.lastModifiedDate)' <<<"$PAYLOAD")"

preflight_write_state

set +e
RESPONSE="$(${SCRIPT_DIR}/graymatter_api.sh POST /MemoryEntry/write "$PAYLOAD" 2>&1)"
STATUS=$?
set -e

if [[ $STATUS -eq 0 ]]; then
  printf '%s\n' "$RESPONSE"
  exit 0
fi

if [[ -n "$TAGS_RAW" ]] && printf '%s' "$RESPONSE" | grep -Eqi 'tags|tag|relation'; then
  echo "Tagged write failed, retrying without tags due to backend tag persistence issue" >&2
  FALLBACK_PAYLOAD="$(jq 'del(.tags)' <<<"$PAYLOAD")"
  exec "${SCRIPT_DIR}/graymatter_api.sh" POST /MemoryEntry/write "$FALLBACK_PAYLOAD"
fi

TEXT_LEN=${#TEXT}
if printf '%s' "$RESPONSE" | grep -Eqi 'data too long|value too long|string or binary data would be truncated|max.?length|payload too large|413|entity too large|request entity too large'; then
  echo "gm-write rejected payload length (chars=${TEXT_LEN})." >&2
  echo "Hint: split text into smaller entries or summarize before writing." >&2
fi

if [[ $STATUS -ne 0 ]]; then
  echo "gm-write failed (type=${TYPE}, sourceChannel=${SOURCE_CHANNEL}, chars=${TEXT_LEN}, exit=${STATUS})." >&2
fi

queue_fallback "gm-write API failure (chars=${TEXT_LEN})"

printf '%s\n' "$RESPONSE" >&2
exit $STATUS
