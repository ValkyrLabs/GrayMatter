#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
OUT="${GRAYMATTER_PLUGIN_PACKAGE_OUT:-$ROOT/graymatter.skill}"

REQUIRED=(
  .codex-plugin/plugin.json
  .app.json
  .mcp.json
  skills/graymatter/SKILL.md
  skills/graymatter-analytics/SKILL.md
  skills/graymatter-analytics/references/semantic-layer-template.md
  skills/graymatter-memory/SKILL.md
  skills/graymatter-memory/agents/openai.yaml
  skills/graymatter-context/SKILL.md
  skills/graymatter-context/agents/openai.yaml
  docs/agent-discovery.md
  docs/awesome-codex-plugins.md
  docs/graymatter-light.md
  docs/knowledge-packs.md
  docs/openai-app-directory-submission.md
  docs/privacy-policy.md
  docs/reviewer-test-credentials.md
  docs/thorapi-integration.md
  openai-app/submission-manifest.json
  SUBMISSION_CHECKLIST.md
  assets/graymatter-logo.png
  clawhub.json
  mcp-server/index.js
  mcp-server/Dockerfile
  mcp-server/package.json
  scripts/gm-activate
  scripts/gm-activation-fastlane
  scripts/gm-invariant-preflight
  scripts/gm-client
  scripts/gm-read
  scripts/gm-doctor
  scripts/gm-install-check
  scripts/gm-mcp-contract
  scripts/gm-agent-smoke-matrix
  scripts/gm-status
  scripts/gm-schema-cache-lib
  scripts/gm-mcp-launcher
  scripts/smoke-test-public-mcp.sh
  scripts/gm-write
  scripts/gm-record
  scripts/gm-light-smoke
  scripts/gm-knowledge-pack-import
  scripts/package-graymatter
  scripts/package_graymatter.sh
  scripts/graymatter_api.sh
  templates/graymatter-light-bootstrap/api.hbs.yaml
  templates/graymatter-light-bootstrap/local-server/bin/graymatter-local-server
  templates/graymatter-light-bootstrap/local-server/manifest.json
  references/contracts/mcp/graymatter_mcp_contract_v1.json
  references/contracts/mcp/graymatter_mcp_tools_v1.json
  references/mcp/memory-tool-contract.v1.json
)

command -v zip >/dev/null 2>&1 || {
  echo "plugins/graymatter/scripts/package-graymatter requires zip" >&2
  exit 1
}

missing=()
for rel in "${REQUIRED[@]}"; do
  [[ -f "$ROOT/$rel" ]] || missing+=("$rel")
done
if [[ ${#missing[@]} -gt 0 ]]; then
  echo "Missing required plugin files:" >&2
  printf '  - %s\n' "${missing[@]}" >&2
  exit 1
fi

if find "$ROOT" -type l -print -quit | grep -q .; then
  echo "Symlinks are not allowed in the GrayMatter plugin package" >&2
  find "$ROOT" -type l -print >&2
  exit 1
fi

grep -q 'name: graymatter' "$ROOT/skills/graymatter/SKILL.md" || {
  echo "GrayMatter skill is missing expected name frontmatter" >&2
  exit 1
}

TMP_DIR="$(mktemp -d "${TMPDIR:-/tmp}/graymatter-plugin.XXXXXX")"
trap 'rm -rf "$TMP_DIR"' EXIT
mkdir -p "$TMP_DIR/graymatter"

while IFS= read -r rel; do
  mkdir -p "$TMP_DIR/graymatter/$(dirname "$rel")"
  cp "$ROOT/$rel" "$TMP_DIR/graymatter/$rel"
  if [[ "$rel" == scripts/* ]]; then
    chmod 755 "$TMP_DIR/graymatter/$rel"
  fi
  touch -t 198001010000 "$TMP_DIR/graymatter/$rel"
done < <(
  cd "$ROOT"
  find . -type f \
    ! -path './graymatter.skill' \
    ! -path './node_modules/*' \
    ! -path './tmp/*' \
    ! -path './dist/*' \
    ! -path './.git/*' \
    | sed 's#^\./##' \
    | sort
)

# zip records directory entries as well as files. Normalize their timestamps so
# repeated builds from identical source produce byte-for-byte identical output.
find "$TMP_DIR/graymatter" -type d -exec touch -t 198001010000 {} +

rm -f "$OUT"
(cd "$TMP_DIR" && zip -X -q -r "$OUT" graymatter)

zip_listing="$(unzip -Z1 "$OUT")"
for rel in "${REQUIRED[@]}"; do
  grep -Fxq "graymatter/$rel" <<<"$zip_listing" || {
    echo "Packaged archive missing required file: $rel" >&2
    exit 1
  }
done

printf 'Packaged %s\n' "$OUT"
