{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://valkyrlabs.com/graymatter/contracts/mcp/v1",
  "title": "GrayMatter MCP Portable Tool Contract v1",
  "type": "object",
  "required": ["version", "memoryContract", "tools"],
  "additionalProperties": false,
  "properties": {
    "version": {"const": "v1"},
    "memoryContract": {
      "type": "object",
      "required": [
        "durableMemoryMode",
        "sourceOfTruth",
        "authPosture",
        "startupRequiredAction",
        "taskStartQueries",
        "localFallbackPolicy"
      ],
      "additionalProperties": true,
      "properties": {
        "durableMemoryMode": {"const": "exclusive_primary_graymatter"},
        "sourceOfTruth": {"const": "api-0"},
        "authPosture": {"const": "authenticate_first"},
        "startupRequiredAction": {"const": "run_graymatter_invariant_preflight_before_planning_or_edits"},
        "taskStartQueries": {
          "type": "array",
          "items": {"type": "string"},
          "contains": {"const": "organizational_truth"}
        },
        "localFallbackPolicy": {"const": "temporary_replay_queue_only_delete_after_successful_sync"}
      }
    },
    "tools": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "required": ["name", "inputSchema", "outputSchema", "errors"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "memory_query",
              "memory_retrieve_with_receipt",
              "retrieval_receipt_get",
              "retrieval_receipt_query",
              "memory_get",
              "memory_put",
              "memory_put_batch",
              "memory_link",
              "memory_health",
              "memory_replay_deferred"
            ]
          },
          "inputSchema": {"type": "object"},
          "outputSchema": {"type": "object"},
          "errors": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["code", "retryable"],
              "additionalProperties": false,
              "properties": {
                "code": {"type": "string", "minLength": 1},
                "retryable": {"type": "boolean"}
              }
            }
          }
        }
      }
    }
  }
}
