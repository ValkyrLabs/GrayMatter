#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BASE="${VALKYR_API_BASE:-https://api-0.valkyrlabs.com/v1}"
USERNAME_ENV="${GRAYMATTER_USERNAME:-${VALKYR_USERNAME:-}}"
PASSWORD_ENV="${GRAYMATTER_PASSWORD:-${VALKYR_PASSWORD:-}}"
INSTANCE_ID="${OPENCLAW_INSTANCE_ID:-${HOSTNAME:-openclaw-instance}}"
AGENT_NAME="${OPENCLAW_AGENT_NAME:-Valor}"
ROLE_LABEL="${OPENCLAW_AGENT_ROLE:-openclaw-server}"
KEYCHAIN_SERVICE="${VALKYR_KEYCHAIN_SERVICE:-VALKYR_AUTH}"

have() {
  command -v "$1" >/dev/null 2>&1
}

if ! have jq; then
  echo "jq is required" >&2
  exit 1
fi

export VALKYR_API_BASE="$BASE"
if [[ -z "$USERNAME_ENV" || -z "$PASSWORD_ENV" ]]; then
  echo "GrayMatter username/password not found in environment; gm-login will attempt keychain-based reauth before interactive fallback" >&2
fi
eval "$(${SCRIPT_DIR}/gm-login env)"

${SCRIPT_DIR}/gm-install-check
SMOKE_DEGRADED=0
set +e
SMOKE_OUTPUT="$(${SCRIPT_DIR}/gm-smoke 2>&1)"
SMOKE_STATUS=$?
set -e
if [[ $SMOKE_STATUS -eq 0 ]]; then
  printf '%s\n' "$SMOKE_OUTPUT"
else
  printf '%s\n' "$SMOKE_OUTPUT" >&2
  if [[ "$SMOKE_OUTPUT" == *"402"* || "$SMOKE_OUTPUT" == *"INSUFFICIENT_FUNDS"* || "$SMOKE_OUTPUT" == *"Payment Required"* ]]; then
    echo "GrayMatter smoke query is credit-gated; continuing with limited memory query capability" >&2
    SMOKE_DEGRADED=1
  else
    echo "GrayMatter smoke test failed" >&2
    exit $SMOKE_STATUS
  fi
fi
${SCRIPT_DIR}/gm-register-agent "$INSTANCE_ID" "$AGENT_NAME" "$ROLE_LABEL"
${SCRIPT_DIR}/gm-openapi-sync >/dev/null
${SCRIPT_DIR}/gm-openapi-summary

if [[ $SMOKE_DEGRADED -eq 1 ]]; then
  echo "GrayMatter activation complete with limited memory query capability: auth ready, agent registered, schema synced" >&2
else
  echo "GrayMatter activation complete: auth ready, smoke test passed, agent registered, schema synced" >&2
fi
