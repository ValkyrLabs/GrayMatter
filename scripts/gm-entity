#!/usr/bin/env bash
set -euo pipefail

ENTITY="${1:-}"
ARG2="${2:-}"
ARG3="${3:-}"
ARG4="${4:-}"

usage() {
  echo "Usage:" >&2
  echo "  gm-entity <Entity>                # list via GET /<Entity>" >&2
  echo "  gm-entity <Entity> <id>           # get via GET /<Entity>/<id>" >&2
  echo "  gm-entity <Entity> POST '<json>'  # create via POST /<Entity>" >&2
  echo "  gm-entity <Entity> PUT  '<json>'  # replace via PUT /<Entity>" >&2
  echo "  gm-entity <Entity> PATCH '<json>' # patch via PATCH /<Entity>" >&2
  echo "  gm-entity <Entity> <id> PUT  '<json>'  # replace via PUT /<Entity>/<id>" >&2
  echo "  gm-entity <Entity> <id> PATCH '<json>' # patch via PATCH /<Entity>/<id>" >&2
  echo "  gm-entity <Entity> <id> DELETE          # delete via DELETE /<Entity>/<id>" >&2
}

if [[ -z "$ENTITY" || "$ENTITY" == "-h" || "$ENTITY" == "--help" ]]; then
  usage
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

validate_entity_payload() {
  local entity="$1"
  local body="$2"
  local limit field length

  case "$entity" in
    StrategicPriority) field="description"; limit=255 ;;
    Note) field="content"; limit=255 ;;
    *) return 0 ;;
  esac

  if [[ -z "$body" ]] || ! command -v jq >/dev/null 2>&1; then
    return 0
  fi

  length="$(printf '%s' "$body" | jq -r --arg field "$field" '
    if type == "object" and has($field) and (.[$field] | type == "string")
    then (.[$field] | length)
    else 0
    end
  ' 2>/dev/null || printf '0')"

  if [[ "$length" =~ ^[0-9]+$ && "$length" -gt "$limit" ]]; then
    echo "error: ${entity}.${field} is ${length} characters; current api-0 runtime rejects values over ${limit} with a SQL truncation 500" >&2
    echo "hint: shorten ${entity}.${field} or store long-form operating context in MemoryEntry/ContentData until the api-0 storage column is expanded" >&2
    exit 64
  fi
}

if [[ -z "$ARG2" ]]; then
  exec "${SCRIPT_DIR}/graymatter_api.sh" GET "/${ENTITY}"
fi

case "$ARG2" in
  GET|get|POST|post|PUT|put|PATCH|patch|DELETE|delete)
    METHOD="$(printf '%s' "$ARG2" | tr '[:lower:]' '[:upper:]')"
    BODY="${ARG3:-}"
    validate_entity_payload "$ENTITY" "$BODY"
    exec "${SCRIPT_DIR}/graymatter_api.sh" "$METHOD" "/${ENTITY}" "$BODY"
    ;;
  *)
    case "$ARG3" in
      GET|get|POST|post|PUT|put|PATCH|patch|DELETE|delete)
        METHOD="$(printf '%s' "$ARG3" | tr '[:lower:]' '[:upper:]')"
        BODY="${ARG4:-}"
        validate_entity_payload "$ENTITY" "$BODY"
        exec "${SCRIPT_DIR}/graymatter_api.sh" "$METHOD" "/${ENTITY}/${ARG2}" "$BODY"
        ;;
      *)
        exec "${SCRIPT_DIR}/graymatter_api.sh" GET "/${ENTITY}/${ARG2}"
        ;;
    esac
    ;;
esac
