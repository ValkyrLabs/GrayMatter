#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 3 ]]; then
  echo "Usage: gm-fallback-append <type> <text> <owner> [reason]" >&2
  exit 1
fi

TYPE="$1"
TEXT="$2"
OWNER="$3"
REASON="${4:-GrayMatter write fallback}"
ROOT_DIR="${ROOT_DIR:-$(pwd)}"
SPOOL="${GRAYMATTER_FALLBACK_SPOOL:-${ROOT_DIR}/memory/graymatter-fallback.json}"
NOW="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"

command -v jq >/dev/null 2>&1 || {
  echo "gm-fallback-append requires jq" >&2
  exit 1
}

mkdir -p "$(dirname "$SPOOL")"
TMP="${SPOOL}.$$"

if [[ -f "$SPOOL" ]]; then
  jq -n \
    --slurpfile current "$SPOOL" \
    --arg now "$NOW" \
    --arg type "$TYPE" \
    --arg text "$TEXT" \
    --arg owner "$OWNER" \
    --arg reason "$REASON" '
      def normalized:
        ($current[0] // null) as $data
        | if ($data | type) == "object" then
            $data | .items = ((.items // []) | if type == "array" then . else [] end)
          elif ($data | type) == "array" then
            {timestamp:$now, source:"chat", status:"pending_replay", items:$data}
          else
            {timestamp:$now, source:"chat", status:"pending_replay", items:[]}
          end;
      normalized
      | .timestamp = $now
      | .source = (.source // "chat")
      | .status = "pending_replay"
      | .items =
        ((.items // []) as $items
        | if any($items[]?; .type == $type and .text == $text and .owner == $owner) then
            $items
            | map(
                if .type == $type and .text == $text and .owner == $owner then
                  .reason = $reason
                  | .lastSeenAt = $now
                  | .firstSeenAt = (.firstSeenAt // .timestamp // $now)
                  | .duplicateCount = ((.duplicateCount // 0) + 1)
                else
                  .
                end
              )
          else
            $items + [{type:$type, text:$text, owner:$owner, reason:$reason, firstSeenAt:$now, lastSeenAt:$now, duplicateCount:0}]
          end)
    ' >"$TMP"
else
  jq -n \
    --arg now "$NOW" \
    --arg type "$TYPE" \
    --arg text "$TEXT" \
    --arg owner "$OWNER" \
    --arg reason "$REASON" \
    '{timestamp:$now, source:"chat", status:"pending_replay", items:[{type:$type, text:$text, owner:$owner, reason:$reason, firstSeenAt:$now, lastSeenAt:$now, duplicateCount:0}]}' >"$TMP"
fi

mv "$TMP" "$SPOOL"
