def write_application_bundle(bundle_dir: Path) -> None:
    template = {
        "key": "graymatter-local",
        "name": "GrayMatter Local Server",
        "description": "Standalone downloadable GrayMatter application generated from ValkyrAI app-factory inputs.",
        "deployProfile": "web-plus-api",
        "generationMode": "thorapi-febe",
        "workflow": {"defaultFlow": "graymatter-local-bootstrap"},
        "billingModel": "one-time",
        "sourceTemplate": "graymatter-local",
        "sharedModules": {
            "auth": {"provider": "thorapi-session", "roles": ["owner", "admin", "member"]},
            "workflow": {"engine": "mcp.workflow.execute", "defaultFlow": "graymatter-local-bootstrap"},
            "swarm": {"protocol": "graymatter-swarm-v0.1", "component": "swarm-protocol"},
            "promotion": {"target": "https://valkyrlabs.com", "component": "mothership-sync"},
        },
        "openApiSchemaRef": "./openapi.json",
        "customComponents": [
            "GrayMatterDashboard",
            "MemoryEntryWorkbench",
            "MothershipPromotionBridge",
            "SwarmProtocolBridge",
            "LiveTelemetryPanel",
        ],
        "builtInValkyrComponents": ["rbac-core", "data-workbooks"],
    }
    workflow = {
        "id": "graymatter-local-bootstrap",
        "name": "GrayMatter Local Bootstrap",
        "steps": [
            {
                "id": "resolve-template",
                "type": "service-call",
                "config": {
                    "service": "thorapi.app.template.resolve",
                    "inputMap": {"templateKey": "graymatter-local"},
                },
            },
            {
                "id": "compose-thorapi-febe",
                "type": "service-call",
                "config": {
                    "service": "thorapi.app.launch.contract",
                    "inputMap": {
                        "templateKey": "graymatter-local",
                        "deployProfile": "web-plus-api",
                        "generationMode": "thorapi-febe",
                        "openApiSchemaPath": "application-bundle/openapi.json",
                        "components": [
                            "components/graymatter-dashboard.yaml",
                            "components/memory-workbench.yaml",
                            "components/mothership-sync.yaml",
                            "components/swarm-protocol.yaml",
                            "components/live-telemetry.yaml",
                            "valkyr-components/rbac-core.yaml",
                            "valkyr-components/data-workbooks.yaml",
                        ],
                    },
                },
            },
        ],
    }

    write_file(bundle_dir / "template.json", json.dumps(template, indent=2) + "\n")
    write_file(bundle_dir / "openapi.json", json.dumps(graymatter_openapi_spec(), indent=2) + "\n")
    write_file(bundle_dir / "workflows/graymatter-local-bootstrap.workflow.json", json.dumps(workflow, indent=2) + "\n")
    write_file(bundle_dir / "thorapi/graymatter-local.bundle.yaml", THORAPI_BUNDLE_YAML)
    write_file(bundle_dir / "components/graymatter-dashboard.yaml", GRAYMATTER_DASHBOARD_COMPONENT)
    write_file(bundle_dir / "components/memory-workbench.yaml", MEMORY_WORKBENCH_COMPONENT)
    write_file(bundle_dir / "components/mothership-sync.yaml", MOTHERSHIP_SYNC_COMPONENT)
    write_file(bundle_dir / "components/swarm-protocol.yaml", SWARM_PROTOCOL_COMPONENT)
    write_file(bundle_dir / "components/live-telemetry.yaml", LIVE_TELEMETRY_COMPONENT)
    write_file(bundle_dir / "valkyr-components/rbac-core.yaml", RBAC_CORE_COMPONENT)
    write_file(bundle_dir / "valkyr-components/data-workbooks.yaml", DATA_WORKBOOKS_COMPONENT)


def write_local_server(local_server_dir: Path) -> None:
    package_dir = local_server_dir / "src/main/java/com/valkyrlabs/graymatter/localserver"
    manifest = {
        "artifactId": "graymatter-local-server",
        "version": "0.1.0",
        "java": "17",
        "generationMode": "thorapi-febe",
        "sourceTemplate": "graymatter-local",
        "customComponents": [
            "GrayMatterDashboard",
            "MemoryEntryWorkbench",
            "MothershipPromotionBridge",
            "SwarmProtocolBridge",
            "LiveTelemetryPanel",
        ],
        "builtInValkyrComponents": ["rbac-core", "data-workbooks"],
        "coreServices": [
            "RBAC",
            "Principal",
            "UserPreferences",
            "MemoryEntry",
            "Data Workbooks",
            "Mothership Sync",
            "Swarm Protocol",
            "Live Telemetry",
        ],
        "dashboard": "http://localhost:8787",
        "mothership": "https://valkyrlabs.com",
        "apiBase": "https://api-0.valkyrlabs.com/v1",
        "swarmProtocol": "graymatter-swarm-v0.1",
        "database": "local H2",
    }

    write_file(local_server_dir / "pom.xml", POM_XML)
    write_file(local_server_dir / "README.md", README_LOCAL_SERVER)
    write_file(local_server_dir / "manifest.json", json.dumps(manifest, indent=2) + "\n")
    write_file(local_server_dir / "bin/graymatter-local-server", LAUNCHER, stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)
    write_file(package_dir / "GrayMatterLocalServerApplication.java", APP_JAVA)
    write_file(package_dir / "config/SecurityConfig.java", SECURITY_CONFIG)
    write_file(package_dir / "bootstrap/AdminBootstrap.java", ADMIN_BOOTSTRAP)
    write_file(package_dir / "model/PrincipalRecord.java", PRINCIPAL_RECORD)
    write_file(package_dir / "model/UserPreferences.java", USER_PREFERENCES)
    write_file(package_dir / "model/MemoryEntry.java", MEMORY_ENTRY)
    write_file(package_dir / "model/WorkbookRecord.java", WORKBOOK_RECORD)
    write_file(package_dir / "repository/PrincipalRecordRepository.java", PRINCIPAL_REPOSITORY)
    write_file(package_dir / "repository/UserPreferencesRepository.java", USER_PREFERENCES_REPOSITORY)
    write_file(package_dir / "repository/MemoryEntryRepository.java", MEMORY_ENTRY_REPOSITORY)
    write_file(package_dir / "repository/WorkbookRecordRepository.java", WORKBOOK_RECORD_REPOSITORY)
    write_file(package_dir / "controller/DashboardController.java", DASHBOARD_CONTROLLER)
    write_file(package_dir / "controller/MemoryEntryController.java", MEMORY_ENTRY_CONTROLLER)
    write_file(package_dir / "controller/LiveTelemetryController.java", LIVE_TELEMETRY_CONTROLLER)
    write_file(package_dir / "controller/MothershipSyncController.java", MOTHERSHIP_SYNC_CONTROLLER)
    write_file(package_dir / "controller/SwarmProtocolController.java", SWARM_PROTOCOL_CONTROLLER)
    write_file(package_dir / "controller/UserPreferencesController.java", USER_PREFERENCES_CONTROLLER)
    write_file(package_dir / "controller/WorkbookController.java", WORKBOOK_CONTROLLER)
    write_file(local_server_dir / "src/main/resources/application.properties", APPLICATION_PROPERTIES)
    write_file(local_server_dir / "src/main/resources/static/index.html", STATIC_INDEX_V2)


def main() -> int:
    parser = argparse.ArgumentParser(description="Create a GrayMatter Light local bundle")
    parser.add_argument("out_dir", nargs="?", default="graymatter-light-bundle")
    args = parser.parse_args()

    out_dir = Path(args.out_dir).resolve()
    dashboard_dir = out_dir / "dashboard"
    data_dir = out_dir / "data"

    out_dir.mkdir(parents=True, exist_ok=True)
    dashboard_dir.mkdir(parents=True, exist_ok=True)
    data_dir.mkdir(parents=True, exist_ok=True)

    spec = EXAMPLE_SPEC.read_text(encoding="utf-8")
    write_file(out_dir / "api.hbs.yaml", spec)
    write_file(out_dir / "docker-compose.yaml", DOCKER_COMPOSE)
    write_file(dashboard_dir / "index.html", DASHBOARD_HTML)
    write_file(out_dir / "UPGRADE.md", UPGRADE_NOTE)
    write_application_bundle(out_dir / "application-bundle")
    write_local_server(out_dir / "local-server")

    os.makedirs(out_dir / "local-server/data", exist_ok=True)

    print(f"Created GrayMatter Light bundle at {out_dir}")
    print("Next: docker compose up -d or local-server/bin/graymatter-local-server")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
