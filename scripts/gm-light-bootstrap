  <script>
    (() => {
      const $ = (id) => document.getElementById(id);
      const elements = {
        username: $("username"),
        password: $("password"),
        session: $("session"),
        sessionTitle: $("sessionTitle"),
        sessionBannerText: $("sessionBannerText"),
        dashboard: $("dashboard"),
        metrics: $("metrics"),
        servicePills: $("servicePills"),
        syncStatus: $("syncStatus"),
        syncOutput: $("syncOutput"),
        swarmStatus: $("swarmStatus"),
        swarmPills: $("swarmPills"),
        telemetryStatus: $("telemetryStatus"),
        telemetryMetrics: $("telemetryMetrics"),
        entries: $("entries"),
        type: $("type"),
        tags: $("tags"),
        text: $("text")
      };

      const state = { dashboard: null, sync: null, swarm: null, telemetry: null };
      const escapeHtml = (value) => String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
      const authHeader = () => "Basic " + btoa(`${elements.username.value}:${elements.password.value}`);
      const plainHeaders = () => ({ "Authorization": authHeader() });
      const jsonHeaders = () => ({ ...plainHeaders(), "Content-Type": "application/json" });

      async function requestJson(url, options = {}) {
        const response = await fetch(url, options);
        if (!response.ok) throw new Error(`${url} failed: ${response.status}`);
        return response.json();
      }

      function renderDashboard(data) {
        state.dashboard = data;
        elements.sessionTitle.textContent = `Connected as ${data.principal.username}`;
        elements.sessionBannerText.textContent = `${data.product} is running in ${data.generationMode} mode.`;
        elements.dashboard.innerHTML = `
          <strong>${escapeHtml(data.product)}</strong>
          <p>Principal <code>${escapeHtml(data.principal.displayName)}</code> has RBAC roles <code>${escapeHtml(data.principal.roles.join(", "))}</code>.</p>
          <p>Bundle <code>${escapeHtml(data.bundle.id)}</code> is generated through <code>${escapeHtml(data.bundle.generationMode)}</code> with local H2 storage.</p>
        `;
        elements.metrics.innerHTML = [
          ["MemoryEntry", data.memoryEntryCount],
          ["Data Workbooks", data.workbookCount],
          ["RBAC", data.preferencesReady ? "Ready" : "Pending"],
          ["Swarm", data.swarmProtocol.protocolVersion]
        ].map(([label, value]) => `<div class="metric"><span>${escapeHtml(label)}</span><strong>${escapeHtml(value)}</strong></div>`).join("");
        elements.servicePills.innerHTML = data.coreServices
          .map((service) => `<span class="pill">${escapeHtml(service)}</span>`)
          .join("");
      }

      function renderStatusLines(target, rows) {
        target.innerHTML = rows
          .map(([label, value]) => `<div class="status-line"><span>${escapeHtml(label)}</span><strong>${escapeHtml(value)}</strong></div>`)
          .join("");
      }

      function renderSync(data) {
        state.sync = data;
        renderStatusLines(elements.syncStatus, [
          ["State", data.state],
          ["Target", data.target],
          ["API", data.apiBase],
          ["Auth", data.auth?.environmentVariable || data.requiresAuth || "VALKYR_AUTH_TOKEN"]
        ]);
      }

      function renderSwarm(data) {
        state.swarm = data;
        renderStatusLines(elements.swarmStatus, [
          ["Protocol", data.protocolVersion],
          ["Node", data.node?.nodeId || "local"],
          ["Role", data.node?.role || "light-node"],
          ["State", data.state]
        ]);
        elements.swarmPills.innerHTML = (data.capabilities || [])
          .map((capability) => `<span class="pill">${escapeHtml(capability)}</span>`)
          .join("");
      }

      function renderTelemetry(data) {
        state.telemetry = data;
        renderStatusLines(elements.telemetryStatus, [
          ["Panel", data.panel],
          ["Section", data.section],
          ["Mode", data.mode],
          ["Admin", data.principal?.admin ? "yes" : "no"]
        ]);
        elements.telemetryMetrics.innerHTML = (data.metrics || [])
          .map((metric) => `<div class="metric"><span>${escapeHtml(metric.label)}</span><strong>${escapeHtml(metric.value)} ${escapeHtml(metric.unit || "")}</strong></div>`)
          .join("");
      }

      function renderEntries(data) {
        elements.entries.innerHTML = data.length
          ? data.map((entry) => `
              <div class="entry">
                <span>${escapeHtml(entry.type || "context")}</span>
                <strong>${escapeHtml(entry.text || "Untitled Memory")}</strong>
                <p>${escapeHtml(entry.tags || "local")}</p>
              </div>`).join("")
          : "<p>No memory entries yet. Create one to seed the local graph.</p>";
      }

      async function loadDashboard() {
        const data = await requestJson("/api/graymatter/dashboard", { headers: plainHeaders() });
        document.body.classList.add("authenticated");
        elements.session.textContent = "";
        renderDashboard(data);
      }

      async function loadSyncStatus() {
        renderSync(await requestJson("/api/graymatter/sync/status", { headers: plainHeaders() }));
      }

      async function loadSwarm() {
        renderSwarm(await requestJson("/api/graymatter/swarm/protocol", { headers: plainHeaders() }));
      }

      async function loadTelemetry() {
        renderTelemetry(await requestJson("/api/graymatter/telemetry/status", { headers: plainHeaders() }));
      }

      async function loadEntries() {
        renderEntries(await requestJson("/api/memory-entries", { headers: plainHeaders() }));
      }

      async function establishSession() {
        try {
          elements.session.textContent = "Connecting...";
          await loadDashboard();
          await Promise.all([loadSyncStatus(), loadSwarm(), loadTelemetry(), loadEntries()]);
        } catch (error) {
          document.body.classList.remove("authenticated");
          elements.session.textContent = error.message;
        }
      }

      async function checkHealth(target = elements.session) {
        const response = await fetch("/actuator/health");
        target.textContent = `Health ${response.status}`;
      }

      $("connect").onclick = establishSession;
      $("refreshAll").onclick = establishSession;
      $("refresh").onclick = async () => {
        try { await loadEntries(); } catch (error) { elements.sessionBannerText.textContent = error.message; }
      };
      $("health").onclick = () => checkHealth(elements.sessionBannerText);
      $("loginHealth").onclick = () => checkHealth(elements.session);
      $("themeToggle").onclick = () => document.body.classList.toggle("light");

      $("promote").onclick = async () => {
        try {
          const response = await requestJson("/api/graymatter/sync/mothership", {
            method: "POST",
            headers: plainHeaders()
          });
          elements.syncOutput.textContent = JSON.stringify(response, null, 2);
          await loadSyncStatus();
        } catch (error) {
          elements.syncOutput.textContent = error.message;
        }
      };

      $("save").onclick = async () => {
        try {
          await requestJson("/api/memory-entries", {
            method: "POST",
            headers: jsonHeaders(),
            body: JSON.stringify({
              type: elements.type.value,
              tags: elements.tags.value,
              text: elements.text.value,
              sourceChannel: "graymatter-local-dashboard"
            })
          });
          await loadDashboard();
          await Promise.all([loadEntries(), loadSyncStatus(), loadSwarm(), loadTelemetry()]);
        } catch (error) {
          elements.sessionBannerText.textContent = error.message;
        }
      };
    })();
  </script>
</body>
</html>
"""

README_LOCAL_SERVER = """# GrayMatter Local Server

GrayMatter Local Server is a downloadable, executable starter for private agent memory.

It runs a minimum Spring Boot server on your machine with:

- RBAC-backed login through Spring Security
- `Principal` identity records
- `UserPreferences` for local user state
- `MemoryEntry` create/query APIs
- Data Workbooks through the `/Workbook` API
- an embedded Valkyr Labs-branded dashboard at `http://localhost:8787`
- a Mothership promotion bridge at `/api/graymatter/sync/*`
- a local GrayMatter SWARM v0.1 light-node adapter at `/api/graymatter/swarm/protocol`
- a ValkyrAI app-factory `application-bundle` with ThorAPI FEBE inputs
- H2 file storage in `./data`
- a Maven native profile for GraalVM/Spring Native builds

## Run

Set local admin credentials before launch:

```bash
export GRAYMATTER_ADMIN_USERNAME=admin
read -rsp "GrayMatter admin password: " GRAYMATTER_ADMIN_PASSWORD
export GRAYMATTER_ADMIN_PASSWORD
bin/graymatter-local-server
```

## Build from source

```bash
cd source
./mvnw package
```

If the archive includes `lib/graymatter-local-server.jar`, the launcher runs it directly.
Otherwise it builds from `source` with local Maven or the Maven wrapper.

## Promote / Synchronize

The dashboard button calls `POST /api/graymatter/sync/mothership`.
This prepares a promotion payload and reports the local bundle, memory, workbook,
and Swarm Protocol state. It does not claim hosted synchronization completed
unless the operator supplies hosted auth such as `VALKYR_AUTH_TOKEN`.

Swarm Protocol status is exposed locally at:

```bash
curl -u "admin:$GRAYMATTER_ADMIN_PASSWORD" http://localhost:8787/api/graymatter/swarm/protocol
```

## Native build

With GraalVM native-image installed:

```bash
cd source
./mvnw -Pnative native:compile
```
"""

LAUNCHER = """#!/usr/bin/env bash
set -euo pipefail

APP_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
JAR="$APP_HOME/lib/graymatter-local-server.jar"
SOURCE_DIR="$APP_HOME/source"

export SERVER_PORT="${SERVER_PORT:-8787}"
mkdir -p "$APP_HOME/data"

if [[ -f "$JAR" ]]; then
  exec java -jar "$JAR" "$@"
fi

if [[ ! -d "$SOURCE_DIR" ]]; then
  echo "GrayMatter Local Server source is missing: $SOURCE_DIR" >&2
  exit 1
fi

cd "$SOURCE_DIR"
if [[ -x ./mvnw ]]; then
  ./mvnw -q -DskipTests package
elif command -v mvn >/dev/null 2>&1; then
  mvn -q -DskipTests package
else
  echo "Java package not bundled and Maven is unavailable. Install Maven or use a native/bundled GrayMatter package." >&2
  exit 1
fi

BUILT_JAR="$(find target -maxdepth 1 -type f -name 'graymatter-local-server-*.jar' ! -name '*sources*' | sort | tail -n 1)"
if [[ -z "$BUILT_JAR" ]]; then
  echo "GrayMatter Local Server build did not produce a runnable jar." >&2
  exit 1
fi

exec java -jar "$BUILT_JAR" "$@"
"""


def write_file(path: Path, content: str, mode: int | None = None) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding="utf-8")
    if mode is not None:
        current_mode = stat.S_IMODE(path.stat().st_mode)
        path.chmod(current_mode | mode)


