    const authHeader = () => "Basic " + btoa(`${username.value}:${password.value}`);
    const jsonHeaders = () => ({ "Authorization": authHeader(), "Content-Type": "application/json" });
    const plainHeaders = () => ({ "Authorization": authHeader() });

    async function loadDashboard() {
      const response = await fetch("/api/graymatter/dashboard", { headers: plainHeaders() });
      if (!response.ok) throw new Error(`Dashboard failed: ${response.status}`);
      const data = await response.json();
      session.textContent = `Connected as ${data.principal.username}`;
      dashboard.innerHTML = `
        <p><strong>${data.product}</strong></p>
        <p>Principal: <code>${data.principal.displayName}</code></p>
        <p>RBAC: <code>${data.principal.roles.join(", ")}</code></p>
        <p>Core services: <code>${data.coreServices.join(", ")}</code></p>
        <p>Memory entries: <code>${data.memoryEntryCount}</code></p>
        <p>Data Workbooks: <code>${data.workbookCount}</code></p>
        <p>Storage: <code>${data.storage}</code></p>
      `;
    }

    async function loadEntries() {
      const response = await fetch("/api/memory-entries", { headers: plainHeaders() });
      if (!response.ok) throw new Error(`Memory query failed: ${response.status}`);
      const data = await response.json();
      entries.innerHTML = data.length
        ? data.map(entry => `<div class="entry"><strong>${entry.type}</strong><div>${entry.text}</div><p>${entry.tags || ""}</p></div>`).join("")
        : "<p>No memory entries yet.</p>";
    }

    connect.onclick = async () => {
      try {
        await loadDashboard();
        await loadEntries();
      } catch (error) {
        session.textContent = error.message;
      }
    };

    health.onclick = async () => {
      const response = await fetch("/actuator/health");
      session.textContent = `Health ${response.status}`;
    };

    refresh.onclick = async () => {
      try { await loadEntries(); } catch (error) { session.textContent = error.message; }
    };

    save.onclick = async () => {
      try {
        const response = await fetch("/api/memory-entries", {
          method: "POST",
          headers: jsonHeaders(),
          body: JSON.stringify({ type: type.value, tags: tags.value, text: text.value })
        });
        if (!response.ok) throw new Error(`Save failed: ${response.status}`);
        await loadDashboard();
        await loadEntries();
      } catch (error) {
        session.textContent = error.message;
      }
    };
  </script>
</body>
</html>
"""

