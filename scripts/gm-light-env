#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
BUNDLE_DIR="${GRAYMATTER_LIGHT_BUNDLE_DIR:-${ROOT_DIR}/.graymatter-light}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --bundle-dir)
      BUNDLE_DIR="$2"
      shift 2
      ;;
    -h|--help)
      echo "Usage: gm-light-env [--bundle-dir DIR]" >&2
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 2
      ;;
  esac
done

ENV_FILE="${BUNDLE_DIR%/}/.graymatter-light-env"
if [[ -f "$ENV_FILE" ]]; then
  cat "$ENV_FILE"
  exit 0
fi

PORT="${GRAYMATTER_LIGHT_PORT:-8080}"
API_BASE="http://localhost:${PORT}"

printf "export VALKYR_API_BASE='%s'\n" "$API_BASE"
printf "export GRAYMATTER_LIGHT_API_BASE='%s'\n" "$API_BASE"
printf "export GRAYMATTER_LIGHT_MODE='true'\n"
printf "export GRAYMATTER_LIGHT_BUNDLE_DIR='%s'\n" "$BUNDLE_DIR"
