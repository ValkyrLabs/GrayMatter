#!/usr/bin/env bash
set -euo pipefail

BASE="${VALKYR_API_BASE:-https://api-0.valkyrlabs.com/v1}"
LOGIN_PATH="${GRAYMATTER_LOGIN_PATH:-/auth/login}"
LOGIN_URL="${BASE%/}/${LOGIN_PATH#/}"
OUT_MODE="${1:-keychain}"
KEYCHAIN_SERVICE="${VALKYR_KEYCHAIN_SERVICE:-VALKYR_AUTH}"
USERNAME_SERVICE="${VALKYR_USERNAME_KEYCHAIN_SERVICE:-${KEYCHAIN_SERVICE}_USERNAME}"
PASSWORD_SERVICE="${VALKYR_PASSWORD_KEYCHAIN_SERVICE:-${KEYCHAIN_SERVICE}_PASSWORD}"
USERNAME="${GRAYMATTER_USERNAME:-${VALKYR_USERNAME:-}}"
PASSWORD="${GRAYMATTER_PASSWORD:-${VALKYR_PASSWORD:-}}"
COOKIE_JAR="$(mktemp -t graymatter-login-cookie.XXXXXX)"
HEADERS_FILE="$(mktemp -t graymatter-login-headers.XXXXXX)"
trap 'rm -f "$COOKIE_JAR" "$HEADERS_FILE"' EXIT

if ! command -v jq >/dev/null 2>&1; then
  echo "jq is required" >&2
  exit 1
fi

load_keychain_secret() {
  local account="$1"
  local service="$2"
  local value=""
  if command -v security >/dev/null 2>&1; then
    value="$(security find-generic-password -a "$account" -s "$service" -w 2>/dev/null || true)"
  fi
  printf '%s' "$value"
}

if [[ -z "$USERNAME" ]]; then
  USERNAME="$(load_keychain_secret default "$USERNAME_SERVICE")"
fi

if [[ -n "$USERNAME" && -z "$PASSWORD" ]]; then
  PASSWORD="$(load_keychain_secret "$USERNAME" "$PASSWORD_SERVICE")"
fi

if [[ -z "$USERNAME" ]]; then
  if [[ ! -t 0 ]]; then
    echo "No reusable GrayMatter credentials found (env/keychain) and interactive login is unavailable." >&2
    echo "Autonomous reauth is impossible from current machine state." >&2
    exit 4
  fi
  read -r -p "GrayMatter username: " USERNAME
fi

prompt_password() {
  if command -v osascript >/dev/null 2>&1; then
    GRAYMATTER_PROMPT_USERNAME="$USERNAME" osascript <<'APPLESCRIPT'
set userName to system attribute "GRAYMATTER_PROMPT_USERNAME"
text returned of (display dialog "Enter the GrayMatter password for " & userName & ":" default answer "" with hidden answer buttons {"Cancel", "OK"} default button "OK" with title "GrayMatter Login")
APPLESCRIPT
    return
  fi

  read -r -s -p "GrayMatter password: " PASSWORD
  printf '\n' >&2
  printf '%s\n' "$PASSWORD"
}

if [[ -z "$PASSWORD" ]]; then
  if [[ ! -t 0 ]]; then
    echo "GrayMatter password not found in env/keychain and interactive login is unavailable." >&2
    echo "Autonomous reauth is impossible from current machine state." >&2
    exit 4
  fi
  PASSWORD="$(prompt_password)"
fi

set +e
RESPONSE="$(curl --fail-with-body -sS -D "$HEADERS_FILE" -c "$COOKIE_JAR" -X POST "$LOGIN_URL" \
  -H 'accept: application/json' \
  -H 'content-type: application/json' \
  --data "$(jq -nc --arg username "$USERNAME" --arg password "$PASSWORD" '{username:$username,password:$password}')" 2>&1)"
CURL_STATUS=$?
set -e

if [[ $CURL_STATUS -ne 0 ]]; then
  echo "GrayMatter login request failed" >&2
  echo "$RESPONSE" >&2
  if [[ -s "$HEADERS_FILE" ]]; then
    echo "Response headers:" >&2
    cat "$HEADERS_FILE" >&2
  fi
  exit $CURL_STATUS
fi

extract_from_body() {
  printf '%s' "$RESPONSE" | jq -r '
    .VALKYR_AUTH //
    .data.VALKYR_AUTH //
    .token //
    .session //
    .jwt //
    .jwtSession //
    .data.jwtSession //
    empty
  ' 2>/dev/null || true
}

extract_from_headers() {
  local token
  token="$(tr -d '\r' < "$HEADERS_FILE" | grep -i 'set-cookie: .*VALKYR_AUTH=' | sed -E 's/.*VALKYR_AUTH=([^;]+).*/\1/' | head -n 1 || true)"
  if [[ -n "$token" ]]; then
    printf '%s\n' "$token"
    return 0
  fi

  token="$(tr -d '\r' < "$HEADERS_FILE" | grep -i '^VALKYR_AUTH:' | sed -E 's/^[^:]+:[[:space:]]*//' | head -n 1 || true)"
  if [[ -n "$token" ]]; then
    printf '%s\n' "$token"
    return 0
  fi

  token="$(tr -d '\r' < "$HEADERS_FILE" | grep -i '^authorization:' | sed -E 's/^[^:]+:[[:space:]]*Bearer[[:space:]]+//' | head -n 1 || true)"
  if [[ -n "$token" ]]; then
    printf '%s\n' "$token"
    return 0
  fi

  token="$(tr -d '\r' < "$HEADERS_FILE" | grep -i 'set-cookie: .*jwtSession=' | sed -E 's/.*jwtSession=([^;]+).*/\1/' | head -n 1 || true)"
  if [[ -n "$token" ]]; then
    printf '%s\n' "$token"
    return 0
  fi
}

extract_from_cookies() {
  awk 'BEGIN{FS="\t"}
    $0 !~ /^#/ && ($6 == "VALKYR_AUTH" || $6 == "jwtSession") {print $7; exit}
  ' "$COOKIE_JAR"
}

AUTH_TOKEN="$(extract_from_body)"
if [[ -z "$AUTH_TOKEN" || "$AUTH_TOKEN" == "null" ]]; then
  AUTH_TOKEN="$(extract_from_headers)"
fi
if [[ -z "$AUTH_TOKEN" || "$AUTH_TOKEN" == "null" ]]; then
  AUTH_TOKEN="$(extract_from_cookies)"
fi

if [[ -z "$AUTH_TOKEN" || "$AUTH_TOKEN" == "null" ]]; then
  echo "Login succeeded but no VALKYR_AUTH token could be extracted from body, headers, or cookies" >&2
  echo "Response body:" >&2
  echo "$RESPONSE" >&2
  echo "Response headers:" >&2
  cat "$HEADERS_FILE" >&2
  exit 2
fi

store_keychain() {
  if ! command -v security >/dev/null 2>&1; then
    echo "macOS security CLI not available for keychain mode" >&2
    exit 3
  fi
  security add-generic-password -U -a "$USERNAME" -s "$KEYCHAIN_SERVICE" -w "$AUTH_TOKEN" >/dev/null
  security add-generic-password -U -a default -s "$KEYCHAIN_SERVICE" -w "$AUTH_TOKEN" >/dev/null
  security add-generic-password -U -a default -s "$USERNAME_SERVICE" -w "$USERNAME" >/dev/null
  security add-generic-password -U -a "$USERNAME" -s "$PASSWORD_SERVICE" -w "$PASSWORD" >/dev/null
  echo "Stored GrayMatter VALKYR_AUTH token securely in macOS/iCloud Keychain service ${KEYCHAIN_SERVICE}" >&2
  echo "Stored GrayMatter credentials securely in macOS/iCloud Keychain" >&2
}

case "$OUT_MODE" in
  keychain)
    store_keychain
    ;;
  env)
    store_keychain
    printf 'export VALKYR_API_BASE="%s"\n' "$BASE"
    printf 'export VALKYR_AUTH_TOKEN="%s"\n' "$AUTH_TOKEN"
    ;;
  token)
    printf '%s\n' "$AUTH_TOKEN"
    ;;
  *)
    echo "Usage: gm-login [keychain|env|token]" >&2
    exit 1
    ;;
esac
