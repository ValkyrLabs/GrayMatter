#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
OUT_JSON="${1:-${ROOT}/tmp/api-docs.json}"
mkdir -p "$(dirname "$OUT_JSON")"

curl -fsSL 'https://api-0.valkyrlabs.com/v1/api-docs' | jq '.' >"$OUT_JSON"
printf '%s\n' "$OUT_JSON"
