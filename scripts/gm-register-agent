#!/usr/bin/env bash
set -euo pipefail

INSTANCE_ID="${1:-${GRAYMATTER_SWARM_ID:-${HOSTNAME:-openclaw-instance}}}"
AGENT_NAME="${2:-${GRAYMATTER_AGENT_NAME:-${OPENCLAW_AGENT_NAME:-Valor}}}"
ROLE_LABEL="${3:-${GRAYMATTER_AGENT_ROLE:-openclaw-server}}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
PLUGIN_VERSION="${GRAYMATTER_PLUGIN_VERSION:-}"
if [[ -z "$PLUGIN_VERSION" && -f "${PLUGIN_ROOT}/.codex-plugin/plugin.json" ]]; then
  PLUGIN_VERSION="$(jq -r '.version // empty' "${PLUGIN_ROOT}/.codex-plugin/plugin.json" 2>/dev/null || true)"
fi
PLUGIN_VERSION="${PLUGIN_VERSION:-unknown}"
METADATA="$(jq -nc \
  --arg name "$AGENT_NAME" \
  --arg role "$ROLE_LABEL" \
  --arg host "$(hostname 2>/dev/null || echo unknown-host)" \
  --arg platform "OpenClaw" \
  --arg memory "GrayMatter" \
  --arg version "$PLUGIN_VERSION" \
  '{name:$name,role:$role,host:$host,platform:$platform,primaryMemory:$memory,version:$version}')"

PAYLOAD="$(jq -nc --arg instanceId "$INSTANCE_ID" --arg metadata "$METADATA" '{instanceId:$instanceId,metadata:$metadata}')"

"${SCRIPT_DIR}/graymatter_api.sh" POST /swarm-ops/register "$PAYLOAD"
