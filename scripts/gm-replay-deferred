#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFERRED_DIR="${GRAYMATTER_DEFERRED_DIR:-${SCRIPT_DIR}/../memory/deferred-ops}"
API_SCRIPT="${GRAYMATTER_API_SCRIPT:-${SCRIPT_DIR}/graymatter_api.sh}"
GRAYMATTER_CREDIT_EVENTS_PATH="${GRAYMATTER_CREDIT_EVENTS_PATH:-${SCRIPT_DIR}/../memory/credit-recovery-events.jsonl}"
LIMIT=""

usage() {
  cat <<'EOF'
Usage:
  gm-replay-deferred [--limit n]

Replay temporary local GrayMatter fallback records into api-0.
Records are removed from the local filesystem only after the durable API write succeeds.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --limit)
      [[ $# -ge 2 ]] || { echo "gm-replay-deferred: --limit requires a value" >&2; exit 1; }
      LIMIT="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown gm-replay-deferred option: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

if [[ -n "$LIMIT" && ! "$LIMIT" =~ ^[0-9]+$ ]]; then
  echo "gm-replay-deferred: --limit must be a non-negative integer: $LIMIT" >&2
  exit 1
fi

replay_preflight() {
  if [[ "${GRAYMATTER_SKIP_REPLAY_PREFLIGHT:-false}" == "true" ]]; then
    return 0
  fi
  local auth_probe tenant_probe
  auth_probe="$(mktemp "${TMPDIR:-/tmp}/graymatter-replay-auth.XXXXXX")"
  tenant_probe="$(mktemp "${TMPDIR:-/tmp}/graymatter-replay-tenant.XXXXXX")"
  trap 'rm -f "$auth_probe" "$tenant_probe"' RETURN
  if ! "$API_SCRIPT" GET auth/me >"$auth_probe" 2>/dev/null; then
    echo "gm-replay-deferred: authenticated connectivity is not restored; queued writes are preserved" >&2
    return 1
  fi
  if ! "$API_SCRIPT" GET 'tenant-schemas/preflight/graymatter_status?operation=memory.query' >"$tenant_probe" 2>/dev/null; then
    echo "gm-replay-deferred: authorized tenant context is not restored; queued writes are preserved" >&2
    return 1
  fi
  if [[ -s "$tenant_probe" ]] && ! jq -e '.ready == true or .tenantSchemaContext == "ready" or .schemaName != null' "$tenant_probe" >/dev/null 2>&1; then
    echo "gm-replay-deferred: api-0 did not confirm the authorized tenant context; queued writes are preserved" >&2
    return 1
  fi
}

emit_replay_event() {
  local event="$1"
  local id="$2"
  local operation="$3"
  local path="$4"
  local event_dir=""

  [[ -n "$GRAYMATTER_CREDIT_EVENTS_PATH" ]] || return 0
  event_dir="$(dirname "$GRAYMATTER_CREDIT_EVENTS_PATH")"
  mkdir -p "$event_dir"

  if command -v jq >/dev/null 2>&1; then
    jq -nc \
      --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
      --arg event "$event" \
      --arg id "$id" \
      --arg operation "$operation" \
      --arg path "$path" \
      '{timestamp:$ts,event:$event,deferredId:$id,operation:$operation,path:$path}' >>"$GRAYMATTER_CREDIT_EVENTS_PATH"
    return 0
  fi

  printf '{"timestamp":"%s","event":"%s","deferredId":"%s","operation":"%s","path":"%s"}\n' \
    "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    "$event" \
    "$id" \
    "$operation" \
    "$path" >>"$GRAYMATTER_CREDIT_EVENTS_PATH"
}

if [[ ! -d "$DEFERRED_DIR" ]]; then
  echo "No deferred operations found."
  exit 0
fi

files=()
while IFS= read -r file; do
  files+=("$file")
done < <(find "$DEFERRED_DIR" -maxdepth 1 -type f -name '*.json' | sort)
if [[ "${#files[@]}" -eq 0 ]]; then
  echo "No deferred operations found."
  exit 0
fi

replay_preflight

processed=0
for file in "${files[@]}"; do
  if [[ -n "$LIMIT" && "$processed" -ge "$LIMIT" ]]; then
    break
  fi
  method="$(jq -r '.method // empty' "$file")"
  path="$(jq -r '.path // empty' "$file")"
  body="$(jq -r '.body // empty' "$file")"
  id="$(jq -r '.id // empty' "$file")"
  operation="$(jq -r '.operation // empty' "$file")"
  if [[ -z "$method" || -z "$path" || -z "$id" ]]; then
    echo "Skipping invalid deferred record: $file" >&2
    continue
  fi
  emit_replay_event "replay_started" "$id" "$operation" "$path"
  if GRAYMATTER_SKIP_DEFERRED=true "$API_SCRIPT" "$method" "$path" "$body" >/dev/null; then
    rm -f "$file"
    emit_replay_event "replay_succeeded" "$id" "$operation" "$path"
    echo "Replayed deferred operation ${id}"
    processed=$((processed + 1))
  else
    echo "Replay failed for ${id}; stopping." >&2
    exit 1
  fi
done
