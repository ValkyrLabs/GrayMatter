#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'EOF'
Usage:
  gm-retrieval-receipt create <query> [topK] [qualityProfile]
  gm-retrieval-receipt get <receiptId>
  gm-retrieval-receipt list [--status STATUS] [--trace-id ID] [--agent-id ID] [--workflow-id ID] [--from ISO] [--to ISO] [--limit N]

Examples:
  gm-retrieval-receipt create "current pricing model" 8 DEFAULT
  gm-retrieval-receipt get gm_rr_123
  gm-retrieval-receipt list --status LOW_CONFIDENCE --limit 20
EOF
}

command -v jq >/dev/null 2>&1 || {
  echo "gm-retrieval-receipt requires jq" >&2
  exit 1
}

cmd="${1:-}"
if [[ -z "$cmd" || "$cmd" == "-h" || "$cmd" == "--help" ]]; then
  usage
  exit 0
fi
shift

append_query_param() {
  local url="$1"
  local key="$2"
  local value="$3"
  local separator="?"

  [[ -n "$value" ]] || {
    printf '%s\n' "$url"
    return 0
  }

  if [[ "$url" == *\?* ]]; then
    separator="&"
  fi

  printf '%s%s%s=%s\n' "$url" "$separator" "$key" "$(jq -rn --arg value "$value" '$value|@uri')"
}

preflight_receipt_state() {
  [[ "${GRAYMATTER_RETRIEVAL_RECEIPT_PREFLIGHT:-true}" == "false" ]] && return 0
  [[ -x "${SCRIPT_DIR}/gm-status" ]] || return 0

  local status_output=""
  status_output="$(GM_STATUS_FORMAT=kv "${SCRIPT_DIR}/gm-status" 2>/dev/null)" || return 0

  local auth_state=""
  local token_state=""
  local tenant_schema_context=""
  local memory_layer=""
  auth_state="$(awk -F= '$1 == "graymatter_auth" {print $2; exit}' <<<"$status_output")"
  token_state="$(awk -F= '$1 == "graymatter_token_state" {print $2; exit}' <<<"$status_output")"
  tenant_schema_context="$(awk -F= '$1 == "tenant_schema_context" {print $2; exit}' <<<"$status_output")"
  memory_layer="$(awk -F= '$1 == "memory_layer" {print $2; exit}' <<<"$status_output")"

  if [[ "$auth_state" == *":read_only"* || "$token_state" == "read_only" ]]; then
    echo "gm-retrieval-receipt cannot use receipt APIs with read-only GrayMatter auth (auth=${auth_state:-unknown}, token=${token_state:-unknown})." >&2
    echo "Use a write-capable VALKYR_AUTH token or run scripts/gm-login with an account that can create/read retrieval receipts." >&2
    exit 23
  fi

  if [[ -n "$tenant_schema_context" && "$tenant_schema_context" != "ready" ]]; then
    echo "gm-retrieval-receipt cannot use receipt APIs while GrayMatter tenant_schema_context=${tenant_schema_context}." >&2
    echo "Deploy or activate a server that resolves tenant schema context, or use a VALKYR_AGENT token that resolves to the main schema." >&2
    exit 25
  fi

  if [[ -n "$memory_layer" && "$memory_layer" != "ready" ]]; then
    echo "gm-retrieval-receipt cannot use receipt APIs while GrayMatter memory_layer=${memory_layer}." >&2
    echo "Run scripts/gm-status and scripts/gm-doctor --quick, then retry." >&2
    exit 24
  fi
}

case "$cmd" in
  create)
    query="${1:-}"
    top_k="${2:-8}"
    quality_profile="${3:-DEFAULT}"
    if [[ -z "$query" ]]; then
      usage >&2
      exit 1
    fi
    body="$(jq -nc \
      --arg query "$query" \
      --argjson topK "$top_k" \
      --arg qualityProfile "$quality_profile" \
      '{query:$query,topK:$topK,retrievalMode:"HYBRID",includeItems:true,includeText:false,includeEvaluator:false,qualityProfile:$qualityProfile}')"
    preflight_receipt_state
    "${SCRIPT_DIR}/graymatter_api.sh" POST /graymatter-retrieval-receipts "$body"
    ;;
  get)
    receipt_id="${1:-}"
    if [[ -z "$receipt_id" ]]; then
      usage >&2
      exit 1
    fi
    preflight_receipt_state
    "${SCRIPT_DIR}/graymatter_api.sh" GET "/graymatter-retrieval-receipts/${receipt_id}"
    ;;
  list|query)
    path="/graymatter-retrieval-receipts"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --status|--retrieval-status)
          path="$(append_query_param "$path" retrievalStatus "${2:-}")"
          shift 2
          ;;
        --trace-id)
          path="$(append_query_param "$path" traceId "${2:-}")"
          shift 2
          ;;
        --agent-id)
          path="$(append_query_param "$path" agentId "${2:-}")"
          shift 2
          ;;
        --workflow-id)
          path="$(append_query_param "$path" workflowId "${2:-}")"
          shift 2
          ;;
        --from)
          path="$(append_query_param "$path" from "${2:-}")"
          shift 2
          ;;
        --to)
          path="$(append_query_param "$path" to "${2:-}")"
          shift 2
          ;;
        --limit)
          path="$(append_query_param "$path" limit "${2:-}")"
          shift 2
          ;;
        *)
          echo "Unknown gm-retrieval-receipt option: $1" >&2
          exit 1
        ;;
      esac
    done
    preflight_receipt_state
    "${SCRIPT_DIR}/graymatter_api.sh" GET "$path"
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
