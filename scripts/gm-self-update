#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
REPO_URL="${GRAYMATTER_PLUGIN_REPO:-https://github.com/ValkyrLabs/GrayMatter}"
CHANNEL="${GRAYMATTER_UPDATE_CHANNEL:-stable}"
MODE="${1:-maybe}"
STATE_DIR="${GRAYMATTER_STATE_DIR:-${HOME:-$ROOT_DIR}/.graymatter}"
INSTALL_ID="${GRAYMATTER_INSTALL_ID:-${OPENCLAW_INSTANCE_ID:-${HOSTNAME:-graymatter-install}}}"
TIMEOUT="${GRAYMATTER_UPDATE_TIMEOUT_SECONDS:-12}"
VERSION_ROOT="${GRAYMATTER_INSTALLATIONS_DIR:-$STATE_DIR/versions}"
PUBLIC_KEY="${GRAYMATTER_RELEASE_PUBLIC_KEY_FILE:-${GRAYMATTER_RELEASE_PUBLIC_KEY:-}}"
MANIFEST_URL="${GRAYMATTER_RELEASE_MANIFEST_URL:-$REPO_URL/releases/latest/download/graymatter-release.json}"
STATE_OVERRIDE="${GRAYMATTER_SELF_UPDATE_STATE:-}"
QUIET="${GRAYMATTER_SELF_UPDATE_QUIET:-false}"

usage() {
  cat <<'EOF'
Usage: gm-self-update [startup|maybe|check|force|active-root|rollback]

Only signed, content-addressed stable releases are accepted. The running
versioned plugin directory is never rewritten.
EOF
}
log() { [[ "$QUIET" == "true" ]] || printf '%s\n' "$*" >&2; }
have() { command -v "$1" >/dev/null 2>&1; }
hash_file() { if have sha256sum; then sha256sum "$1" | awk '{print $1}'; else shasum -a 256 "$1" | awk '{print $1}'; fi; }
now() { date +%s; }

case "$MODE" in
  startup|maybe|check|force|active-root|rollback) ;;
  -h|--help) usage; exit 0 ;;
  *) usage >&2; exit 2 ;;
esac

INSTALL_KEY="$(printf '%s' "$ROOT_DIR|$INSTALL_ID|$CHANNEL" | (sha256sum 2>/dev/null || shasum -a 256) | awk '{print $1}')"
if [[ -n "$STATE_OVERRIDE" ]]; then STATE_FILE="$STATE_OVERRIDE"; else STATE_FILE="$STATE_DIR/update-state/$INSTALL_KEY.json"; fi
LOCK_PATH="$STATE_FILE.lock"
# Rollback/active-version state is isolated with the same installation/channel
# key as the check state; two plugin installs must never switch each other.
ACTIVE_STATE="$STATE_DIR/update-active/$INSTALL_KEY.json"
mkdir -p "$(dirname "$STATE_FILE")" "$(dirname "$ACTIVE_STATE")"

acquire_lock() {
  local started="$(now)"
  while ! mkdir "$LOCK_PATH" 2>/dev/null; do
    if (( $(now) - started >= 20 )); then
      echo "gm-self-update: timed out waiting for installation/channel lock" >&2
      exit 75
    fi
    sleep 0.1
  done
}
release_lock() { rmdir "$LOCK_PATH" 2>/dev/null || true; }
trap release_lock EXIT

write_state() {
  local status="$1"
  local version="${2:-}"
  local error_message="${3:-}"
  local tmp="$(mktemp "${STATE_FILE}.tmp.XXXXXX")"
  jq -n --arg checkedAt "$(date -u +%Y-%m-%dT%H:%M:%SZ)" --argjson checkedAtEpoch "$(now)" \
    --arg status "$status" --arg channel "$CHANNEL" --arg installId "$INSTALL_ID" \
    --arg root "$ROOT_DIR" --arg version "$version" --arg error "$error_message" \
    '{checkedAt:$checkedAt,checkedAtEpoch:$checkedAtEpoch,status:$status,channel:$channel,installId:$installId,root:$root,version:$version,error:$error}' >"$tmp"
  chmod 600 "$tmp"
  mv -f "$tmp" "$STATE_FILE"
}

write_active() {
  local active_root="$1"
  local active_version="$2"
  local previous_root="${3:-}"
  local previous_version="${4:-}"
  local tmp="$(mktemp "${ACTIVE_STATE}.tmp.XXXXXX")"
  jq -n --arg updatedAt "$(date -u +%Y-%m-%dT%H:%M:%SZ)" --arg channel "$CHANNEL" \
    --arg activeRoot "$active_root" --arg activeVersion "$active_version" \
    --arg previousRoot "$previous_root" --arg previousVersion "$previous_version" \
    '{updatedAt:$updatedAt,channel:$channel,activeRoot:$activeRoot,activeVersion:$activeVersion,previousRoot:$previousRoot,previousVersion:$previousVersion}' >"$tmp"
  chmod 600 "$tmp"
  mv -f "$tmp" "$ACTIVE_STATE"
}

if [[ "$MODE" == "active-root" ]]; then
  [[ -f "$ACTIVE_STATE" ]] && jq -r '.activeRoot // empty' "$ACTIVE_STATE"
  exit 0
fi
acquire_lock

if [[ "$MODE" == "rollback" ]]; then
  previous_root="$(jq -r '.previousRoot // empty' "$ACTIVE_STATE" 2>/dev/null || true)"
  previous_version="$(jq -r '.previousVersion // empty' "$ACTIVE_STATE" 2>/dev/null || true)"
  [[ -n "$previous_root" && -d "$previous_root" ]] || { write_state rollback-unavailable "" "no verified previous release"; exit 1; }
  current_root="$(jq -r '.activeRoot // empty' "$ACTIVE_STATE" 2>/dev/null || true)"
  current_version="$(jq -r '.activeVersion // empty' "$ACTIVE_STATE" 2>/dev/null || true)"
  write_active "$previous_root" "$previous_version" "$current_root" "$current_version"
  write_state rolled-back "$previous_version"
  printf 'active_root=%s\n' "$previous_root"
  exit 0
fi

TMP_DIR="$(mktemp -d "${TMPDIR:-/tmp}/graymatter-update.XXXXXX")"
cleanup_tmp() { rm -rf "$TMP_DIR"; release_lock; }
trap cleanup_tmp EXIT
MANIFEST="$TMP_DIR/release.json"
MANIFEST_SIG="$TMP_DIR/release.json.sig"
ARTIFACT="$TMP_DIR/release.artifact"
ARTIFACT_SIG="$TMP_DIR/release.artifact.sig"
TRUSTED_KEY="$TMP_DIR/trusted.pub"

download() {
  have curl || return 1
  curl -fsS --connect-timeout "$TIMEOUT" --max-time "$TIMEOUT" "$1" -o "$2"
}
verify_signature() {
  have openssl && [[ -s "$TRUSTED_KEY" ]] || return 1
  openssl dgst -sha256 -verify "$TRUSTED_KEY" -signature "$2" "$1" >/dev/null
}

if [[ -z "$PUBLIC_KEY" ]]; then
  write_state failed "" "trusted release public key is not configured"
  echo "gm-self-update: release check failed: trusted release public key is not configured" >&2
  exit 1
fi
if [[ -f "$PUBLIC_KEY" ]]; then cp "$PUBLIC_KEY" "$TRUSTED_KEY"; else printf '%s\n' "$PUBLIC_KEY" >"$TRUSTED_KEY"; fi
if ! download "$MANIFEST_URL" "$MANIFEST" || ! download "${GRAYMATTER_RELEASE_MANIFEST_SIGNATURE_URL:-$MANIFEST_URL.sig}" "$MANIFEST_SIG"; then
  write_state failed "" "signed release manifest unavailable"
  echo "gm-self-update: release check failed: signed stable manifest unavailable" >&2
  exit 1
fi
if ! verify_signature "$MANIFEST" "$MANIFEST_SIG"; then
  write_state failed "" "release manifest signature verification failed"
  echo "gm-self-update: release check failed: manifest signature verification failed" >&2
  exit 1
fi

RELEASE_CHANNEL="$(jq -r '.channel // empty' "$MANIFEST")"
RELEASE_VERSION="$(jq -r '.version // empty' "$MANIFEST")"
ARTIFACT_URL="$(jq -r '.artifactUrl // .artifact_url // empty' "$MANIFEST")"
EXPECTED_SHA="$(jq -r '.artifactSha256 // .artifact_sha256 // empty' "$MANIFEST")"
ARTIFACT_SIGNATURE_URL="$(jq -r '.artifactSignatureUrl // .artifact_signature_url // empty' "$MANIFEST")"
[[ -n "$ARTIFACT_SIGNATURE_URL" ]] || ARTIFACT_SIGNATURE_URL="$MANIFEST_URL.artifact.sig"
[[ "$RELEASE_CHANNEL" == "$CHANNEL" && "$RELEASE_VERSION" =~ ^[0-9A-Za-z][0-9A-Za-z.+_-]*$ && -n "$ARTIFACT_URL" && "$EXPECTED_SHA" =~ ^[A-Fa-f0-9]{64}$ ]] || {
  write_state failed "$RELEASE_VERSION" "manifest is not a stable content-addressed release"
  echo "gm-self-update: release check failed: manifest is not a stable content-addressed release" >&2
  exit 1
}

CURRENT_VERSION="$(jq -r '.version // empty' "$ROOT_DIR/.codex-plugin/plugin.json" 2>/dev/null || true)"
if [[ "$CURRENT_VERSION" == "$RELEASE_VERSION" ]]; then
  write_state up-to-date "$CURRENT_VERSION"
  log "GrayMatter plugin ready: signed stable release $CURRENT_VERSION"
  exit 0
fi
if [[ "$MODE" == "maybe" || "$MODE" == "check" ]]; then
  write_state update-available "$RELEASE_VERSION"
  log "GrayMatter signed stable release available: $RELEASE_VERSION"
  exit 0
fi

if ! download "$ARTIFACT_URL" "$ARTIFACT" || ! download "$ARTIFACT_SIGNATURE_URL" "$ARTIFACT_SIG"; then
  write_state failed "$RELEASE_VERSION" "release artifact or signature unavailable"
  echo "gm-self-update: update failed: release artifact or signature unavailable" >&2
  exit 1
fi
[[ "$(hash_file "$ARTIFACT")" == "$EXPECTED_SHA" ]] || {
  write_state failed "$RELEASE_VERSION" "artifact SHA-256 mismatch"
  echo "gm-self-update: update failed: artifact SHA-256 mismatch" >&2
  exit 1
}
if ! verify_signature "$ARTIFACT" "$ARTIFACT_SIG"; then
  write_state failed "$RELEASE_VERSION" "artifact signature verification failed"
  echo "gm-self-update: update failed: artifact signature verification failed" >&2
  exit 1
fi

EXTRACT_DIR="$TMP_DIR/extract"
mkdir -p "$EXTRACT_DIR"
tar -xzf "$ARTIFACT" -C "$EXTRACT_DIR"
PAYLOAD="$EXTRACT_DIR"
[[ -d "$EXTRACT_DIR/graymatter" ]] && PAYLOAD="$EXTRACT_DIR/graymatter"
[[ -f "$PAYLOAD/.codex-plugin/plugin.json" && -f "$PAYLOAD/.mcp.json" && -f "$PAYLOAD/mcp-server/index.js" ]] || {
  write_state failed "$RELEASE_VERSION" "release artifact failed plugin validation"
  echo "gm-self-update: update failed: release artifact failed plugin validation" >&2
  exit 1
}
[[ "$(jq -r '.version // empty' "$PAYLOAD/.codex-plugin/plugin.json")" == "$RELEASE_VERSION" ]] || {
  write_state failed "$RELEASE_VERSION" "artifact version mismatch"
  echo "gm-self-update: update failed: artifact version mismatch" >&2
  exit 1
}

mkdir -p "$VERSION_ROOT"
STAGE_DIR="$(mktemp -d "$VERSION_ROOT/.stage.XXXXXX")"
cp -a "$PAYLOAD/." "$STAGE_DIR/"
chmod 700 "$STAGE_DIR"
FINAL_DIR="$VERSION_ROOT/$RELEASE_VERSION"
if [[ -e "$FINAL_DIR" ]]; then rm -rf "$STAGE_DIR"; else mv -f "$STAGE_DIR" "$FINAL_DIR"; fi
PREVIOUS_ROOT="$(jq -r '.activeRoot // empty' "$ACTIVE_STATE" 2>/dev/null || true)"
PREVIOUS_VERSION="$(jq -r '.activeVersion // empty' "$ACTIVE_STATE" 2>/dev/null || true)"
if [[ "$PREVIOUS_ROOT" != "$FINAL_DIR" ]]; then
  write_active "$FINAL_DIR" "$RELEASE_VERSION" "$PREVIOUS_ROOT" "$PREVIOUS_VERSION"
fi
write_state updated "$RELEASE_VERSION"
printf 'active_root=%s\n' "$FINAL_DIR"
log "GrayMatter plugin staged atomically at $FINAL_DIR; restart is required"
